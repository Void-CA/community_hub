---
import type { ScheduleEntry } from '@/lib/schedules';
import { formatBlock, formatDay, getSubjectColor } from '@/lib/schedules';
import Badge from '@/components/UI/Badge.astro';
import Card from '@/components/UI/Card.astro';

interface Props {
  entry: ScheduleEntry;
  compact?: boolean;
}

const { entry, compact = false } = Astro.props;
const accent = getSubjectColor(entry.subject);
---

<Card
  as="article"
  class:list={['schedule-entry', { 'schedule-entry-compact': compact }]}
  data-schedule-entry
  data-day={entry.day.toLowerCase()}
  data-group={String(entry.group)}
  data-majors={entry.majors.map((major) => major.toLowerCase()).join('|')}
  data-professor={entry.professor.toLowerCase()}
  data-subject={entry.subject.toLowerCase()}
  data-room={entry.room.toLowerCase()}
  style={`--schedule-accent: ${accent};`}
  padding="none"
>
  <div class="schedule-entry-head">
    <div class="schedule-entry-title-group">
      <p class="schedule-kicker">{formatDay(entry.day)}</p>
      <h3>{entry.subject}</h3>
    </div>

    <Badge variant="soft" size="sm">{entry.room}</Badge>
  </div>

  <div class="schedule-meta">
    <div>
      <span>Profesor</span>
      <strong>{entry.professor}</strong>
    </div>

    <div>
      <span>Bloque</span>
      <strong
        >{formatBlock(entry.start_block)} - {
          formatBlock(entry.end_block)
        }</strong
      >
    </div>

    <div>
      <span>Grupo</span>
      <strong>{entry.group}</strong>
    </div>
  </div>

  <div class="schedule-majors">
    {
      entry.majors.map((major) => (
        <Badge variant="accent" size="xs">
          {major}
        </Badge>
      ))
    }
  </div>
</Card>

<style>
  .schedule-entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--schedule-accent) 8%, var(--color-surface) 92%),
      var(--color-surface)
    );
    position: relative;
  }

  .schedule-entry::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: var(--schedule-accent);
  }

  .schedule-entry-compact {
    gap: var(--space-3);
    padding: var(--space-4);
  }

  .schedule-entry-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .schedule-entry-title-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .schedule-kicker {
    margin: 0;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-soft);
  }

  h3 {
    margin: 0;
    font-size: var(--font-size-lg);
  }

  .schedule-meta {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .schedule-meta div {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .schedule-meta span {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .schedule-meta strong {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .schedule-majors {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  @media (max-width: 720px) {
    .schedule-meta {
      grid-template-columns: 1fr;
    }
  }
</style>
