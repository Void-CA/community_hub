---
import type { ScheduleEntry } from '@/lib/schedules';
import { formatAcademicYear, formatBlock, formatDay, getMajorAccent } from '@/lib/schedules';
import Badge from '@/components/UI/Badge.astro';

interface Props {
  entry: ScheduleEntry;
  sectionId: string;
  label?: string;
}

const { entry, sectionId, label } = Astro.props;
const accent = getMajorAccent(entry.majors[0] ?? 'General');
const title = label ?? entry.subject;
---

<article
  class="schedule-tile"
  data-schedule-tile
  data-section-id={sectionId}
  data-major-list={entry.majors.map((major) => major.toLowerCase()).join('|')}
  data-day={entry.day.toLowerCase()}
  data-block={entry.start_block}
  data-professor={entry.professor.toLowerCase()}
  data-subject={entry.subject.toLowerCase()}
  data-room={entry.room.toLowerCase()}
  data-group={String(entry.group)}
  data-academic-year={String(entry.academicYear)}
  data-search={`${entry.subject} ${entry.professor} ${entry.room} ${entry.group}`.toLowerCase()}
  style={`--tile-accent: ${accent};`}
>
  <div class="tile-head">
    <p>{formatDay(entry.day)}</p>
    <span>{formatBlock(entry.start_block).split(' - ')[0]} - {formatBlock(entry.end_block).split(' - ')[1] || formatBlock(entry.end_block).split(' - ')[0]}</span>
  </div>

  <strong>{title}</strong>

  <div class="tile-meta">
    <Badge size="xs" style={`background: color-mix(in srgb, var(--tile-accent) 10%, var(--color-surface-muted));`}>G{entry.group}</Badge>
    <Badge size="xs" style={`background: color-mix(in srgb, var(--tile-accent) 10%, var(--color-surface-muted));`}>{entry.room}</Badge>
    <Badge size="xs" style={`background: color-mix(in srgb, var(--tile-accent) 10%, var(--color-surface-muted));`}>{formatAcademicYear(entry.academicYear)}</Badge>
  </div>

  <p class="tile-professor">{entry.professor}</p>
</article>

<style>
  .schedule-tile {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--tile-accent) 20%, var(--color-border));
    background: linear-gradient(180deg, color-mix(in srgb, var(--tile-accent) 5%, var(--color-surface) 95%), var(--color-surface));
    box-shadow: var(--shadow-sm);
    min-width: 0;
    font-size: 11px;
    cursor: default;
    transition: all 0.2s ease;
  }

  .schedule-tile[hidden] {
    display: none !important;
  }

  .schedule-tile:hover {
    border-color: var(--tile-accent);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    z-index: 10;
  }

  .tile-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-1);
    color: var(--color-text-muted);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  strong {
    font-size: 11px;
    line-height: 1.1;
    margin-bottom: 2px;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .tile-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: auto;
  }

  .tile-professor {
    margin: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
    opacity: 0.8;
  }
</style>
