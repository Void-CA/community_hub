---
import type { ScheduleEntry } from '@/lib/schedules';
import { formatAcademicYear, formatBlock, formatDay, getSubjectColor, getProfessorAlias } from '@/lib/schedules';

interface Props {
  entry: ScheduleEntry;
  sectionId: string;
  label?: string;
  hasConflict?: boolean;
  conflictWith?: string[];
  style?: string;
}

const { entry, sectionId, label, hasConflict = false, conflictWith = [], style: extraStyle = '' } = Astro.props;
const accentColor = getSubjectColor(entry.subject);
const title = label ?? entry.subject;
const professorAlias = getProfessorAlias(entry.professor);

const startTime = formatBlock(entry.start_block).split(' - ')[0];
const endTime = formatBlock(entry.end_block).split(' - ')[1] || formatBlock(entry.end_block).split(' - ')[0];
---

<article
  class:list={['schedule-tile', { 'has-conflict': hasConflict }]}
  data-schedule-tile
  data-section-id={sectionId}
  data-professor={entry.professor.toLowerCase()}
  data-subject={entry.subject.toLowerCase()}
  data-day={entry.day.toLowerCase()}
  data-block={entry.start_block}
  style={`--tile-accent: ${accentColor}; ${extraStyle}`}
>
  <div class="tile-content">
    <header class="tile-header">
      <div class="tile-time">
        {startTime} — {endTime}
      </div>
      <span class="tile-group-badge">G{entry.group}</span>
    </header>
    
    <div class="tile-body">
      <h4 class="tile-subject" title={title}>{title}</h4>
      
      <div class="tile-meta">
        <span class="tile-room">Aula {entry.room}</span>
      </div>
    </div>

    <footer class="tile-footer">
      <p class="tile-professor">{professorAlias}</p>
    </footer>
  </div>

  {hasConflict && <div class="conflict-badge">CONFLICTO</div>}
</article>

<style>
  .schedule-tile {
    display: flex;
    flex-direction: column;
    padding: 0.6rem;
    border-radius: var(--radius-lg);
    border-left: 5px solid var(--tile-accent);
    background: var(--color-surface);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    min-width: 0;
    cursor: default;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    height: 100%;
    border-top: 1px solid var(--color-border-soft);
    border-right: 1px solid var(--color-border-soft);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .schedule-tile:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    z-index: 100 !important;
  }

  .tile-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0.4rem;
  }

  .tile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2px;
  }

  .tile-time {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .tile-group-badge {
    font-size: 9px;
    font-weight: 900;
    padding: 2px 6px;
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border-soft);
    border-radius: 6px;
    color: var(--color-text-soft);
  }

  .tile-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tile-subject {
    margin: 0;
    font-size: 13px; /* Significant increase */
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .tile-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
  }

  .tile-room {
    color: var(--tile-accent);
    filter: brightness(0.8);
  }

  .tile-footer {
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border-soft) 50%, transparent);
  }

  .tile-professor {
    margin: 0;
    font-size: 11px;
    color: var(--color-text-muted);
    font-weight: 500;
    font-style: italic;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Conflict State */
  .has-conflict {
    border-left-color: var(--color-error);
    background: color-mix(in srgb, var(--color-error) 4%, var(--color-surface));
  }

  .conflict-badge {
    position: absolute;
    bottom: 0;
    right: 0;
    background: var(--color-error);
    color: white;
    font-size: 8px;
    font-weight: 900;
    padding: 2px 6px;
    border-top-left-radius: 8px;
    letter-spacing: 0.1em;
  }

  .schedule-tile[hidden] {
    display: none !important;
  }

  /* Adjustments for short spans */
  :global(.timeline-tile-container[style*="span 1"]) .tile-footer {
    display: none;
  }
  
  :global(.timeline-tile-container[style*="span 1"]) .tile-subject {
    -webkit-line-clamp: 1;
  }
</style>
