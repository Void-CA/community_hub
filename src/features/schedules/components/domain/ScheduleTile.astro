---
import type { ScheduleEntry } from "@/lib/schedules";
import {
  formatAcademicYear,
  formatBlock,
  formatDay,
  getSubjectColor,
  getProfessorAlias,
} from "@/lib/schedules";

export type ScheduleTileVariant = "student" | "professor";

interface Props {
  entry: ScheduleEntry;
  sectionId: string;
  label?: string;
  hasConflict?: boolean;
  conflictWith?: string[];
  style?: string;
  variant?: ScheduleTileVariant;
}

const {
  entry,
  sectionId,
  label,
  hasConflict = false,
  conflictWith = [],
  style: extraStyle = "",
  variant = "student",
} = Astro.props;
const accentColor = getSubjectColor(entry.subject);
const title = label ?? entry.subject;
const professorAlias = getProfessorAlias(entry.professor);

const startTime = formatBlock(entry.start_block).split(" - ")[0];
const endTime =
  formatBlock(entry.end_block).split(" - ")[1] ||
  formatBlock(entry.end_block).split(" - ")[0];
---

<article
  class:list={["schedule-tile", { "has-conflict": hasConflict }]}
  data-schedule-tile
  data-section-id={sectionId}
  data-professor={entry.professor.toLowerCase()}
  data-subject={entry.subject.toLowerCase()}
  data-day={entry.day.toLowerCase()}
  data-block={entry.start_block}
  style={`--tile-accent: ${accentColor}; ${extraStyle}`}
>
  <div class="tile-content">
    <header class="tile-header">
      <div class="tile-time">
        {startTime} — {endTime}
      </div>
      <span class="tile-group-badge">G{entry.group}</span>
    </header>

    <div class="tile-body">
      <h4 class="tile-subject" title={title}>{title}</h4>

      <div class="tile-meta">
        <span class="tile-room">Aula {entry.room}</span>
      </div>
    </div>

    <footer class="tile-footer">
      {variant === "student" && (
        <p class="tile-professor">{professorAlias}</p>
      )}
      {variant === "professor" && entry.majors.length > 0 && (
        <span class="tile-major-badge">
          {entry.majors.join(" · ")}{entry.academicYear ? ` · ${entry.academicYear} año` : ""}
        </span>
      )}
    </footer>
  </div>

  {hasConflict && <div class="conflict-badge">CONFLICTO</div>}
</article>

<style>
  .schedule-tile {
    display: flex;
    flex-direction: column;
    padding: var(--tile-padding);
    border-radius: var(--radius-lg);
    border-left: var(--tile-border-accent) solid var(--tile-accent);
    background: var(--color-surface);
    box-shadow: var(--shadow-md);
    min-width: 0;
    cursor: default;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
    height: 100%;
    border-top: var(--border-width-sm) solid var(--color-border-soft);
    border-right: var(--border-width-sm) solid var(--color-border-soft);
    border-bottom: var(--border-width-sm) solid var(--color-border-soft);
  }

  .schedule-tile:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    z-index: 100 !important;
  }

  .tile-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: var(--tile-gap);
  }

  .tile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2px;
  }

  .tile-time {
    font-size: var(--font-size-2xs);
    font-weight: var(--font-weight-extrabold);
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    font-family: var(--font-family-mono);
  }

  .tile-group-badge {
    font-size: var(--font-size-tiny);
    font-weight: var(--font-weight-black);
    padding: 2px 6px;
    background: var(--color-surface-muted);
    border: var(--border-width-sm) solid var(--color-border-soft);
    border-radius: 6px;
    color: var(--color-text-soft);
  }

  .tile-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tile-subject {
    margin: 0;
    font-size: 13px;
    font-weight: var(--font-weight-extrabold);
    line-height: var(--leading-tight, 1.2);
    color: var(--color-text);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .tile-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: var(--font-weight-bold);
  }

  .tile-room {
    color: var(--tile-accent);
  }

  @media (prefers-color-scheme: light) {
    .tile-room {
      filter: brightness(0.8);
    }
  }

  .tile-footer {
    margin-top: auto;
    padding-top: var(--space-2);
    border-top: var(--border-width-sm) solid
      color-mix(in srgb, var(--color-border-soft) 50%, transparent);
  }

  .tile-professor {
    margin: 0;
    font-size: 11px;
    color: var(--color-text-muted);
    font-weight: var(--font-weight-medium);
    font-style: italic;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Professor variant */
  .tile-major-badge {
    font-size: 11px;
    font-weight: var(--font-weight-semibold);
    color: var(--tile-accent);
    letter-spacing: 0.02em;
  }

  /* Conflict State */
  .has-conflict {
    border-left-color: var(--color-error);
    background: color-mix(in srgb, var(--color-error) 4%, var(--color-surface));
  }

  .conflict-badge {
    position: absolute;
    bottom: 0;
    right: 0;
    background: var(--color-error);
    color: white;
    font-size: var(--font-size-micro);
    font-weight: var(--font-weight-black);
    padding: 2px 6px;
    border-top-left-radius: 8px;
    letter-spacing: 0.1em;
  }

  .schedule-tile[hidden] {
    display: none !important;
  }

  /* Adjustments for short spans */
  :global(.timeline-tile-container[style*="span 1"]) .tile-footer {
    display: none;
  }

  :global(.timeline-tile-container[style*="span 1"]) .tile-subject {
    -webkit-line-clamp: 1;
  }
</style>
