---
import type { ScheduleEntry } from '@/lib/schedules';
import { formatAcademicYear, formatBlock, formatDay, getSubjectColor, getProfessorAlias } from '@/lib/schedules';
import Badge from '@/components/UI/Badge.astro';

interface Props {
  entry: ScheduleEntry;
  sectionId: string;
  label?: string;
  hasConflict?: boolean;
  conflictWith?: string[];
  style?: string;
}

const { entry, sectionId, label, hasConflict = false, conflictWith = [], style: extraStyle = '' } = Astro.props;
const accentColor = getSubjectColor(entry.subject);
const title = label ?? entry.subject;
const professorAlias = getProfessorAlias(entry.professor);
---

<article
  class:list={['schedule-tile', { 'has-conflict': hasConflict }]}
  data-schedule-tile
  data-section-id={sectionId}
  data-professor={entry.professor.toLowerCase()}
  data-subject={entry.subject.toLowerCase()}
  data-day={entry.day.toLowerCase()}
  data-block={entry.start_block}
  style={`--tile-accent: ${accentColor}; ${extraStyle}`}
>
  <div class="tile-content">
    <div class="tile-header">
      <strong>{title}</strong>
    </div>
    
    <div class="tile-meta">
      <span class="tile-room">{entry.room}</span>
      <span class="meta-separator">·</span>
      <span class="tile-group">G{entry.group}</span>
    </div>

    <div class="tile-footer">
      <p class="tile-professor">{professorAlias}</p>
    </div>
  </div>

  {hasConflict && <div class="conflict-indicator">!</div>}
</article>

<style>
  .schedule-tile {
    display: flex;
    flex-direction: column;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--tile-accent);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    min-width: 0;
    font-size: 11px;
    cursor: default;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
    height: 100%;
    border-top: 1px solid var(--color-border-soft);
    border-right: 1px solid var(--color-border-soft);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .schedule-tile:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    z-index: 10;
  }

  .tile-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 2px;
  }

  strong {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    color: var(--color-text);
  }

  .tile-meta {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-soft);
  }

  .meta-separator {
    opacity: 0.5;
  }

  .tile-room {
    color: var(--tile-accent);
    font-weight: var(--font-weight-bold);
  }

  .tile-footer {
    margin-top: auto;
    padding-top: 4px;
  }

  .tile-professor {
    margin: 0;
    font-size: 9px;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .has-conflict {
    border-color: var(--color-error);
    background: color-mix(in srgb, var(--color-error) 5%, var(--color-surface));
  }

  .conflict-indicator {
    position: absolute;
    top: 2px;
    right: 4px;
    color: var(--color-error);
    font-weight: var(--font-weight-bold);
    font-size: 12px;
  }

  .schedule-tile[hidden] {
    display: none !important;
  }
</style>
