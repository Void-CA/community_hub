---
import { formatAcademicYear } from '../../../lib/schedules';
import type { ScheduleSection } from '../../../lib/schedules';

interface Props {
  allSections: ScheduleSection[];
  initialMajor: string;
  initialYear: number;
  initialVisibleSections: number;
}

const { allSections, initialMajor, initialYear, initialVisibleSections } = Astro.props;
---

<aside class="catalog card">
  <div class="catalog-head">
    <div>
      <p class="eyebrow">Catálogo</p>
      <h2>Materias y grupos</h2>
    </div>
    <p class="catalog-count text-soft"><span id="visible-section-count">{initialVisibleSections}</span> secciones</p>
  </div>

  <label class="search-box">
    <span class="sr-only">Buscar</span>
    <input id="section-search" type="search" placeholder="Buscar materia, profesor o aula" />
  </label>

  <div class="catalog-list">
    {allSections.map((section) => (
      <button
        type="button"
        class:list={['section-card', { 'is-selected': section.majors.includes(initialMajor) && (initialYear <= 0 || section.academicYears.includes(initialYear)) }]}
        data-section-toggle
        data-section-id={section.id}
        data-major-list={section.majors.map((major) => major.toLowerCase()).join('|')}
        data-year-list={section.academicYears.map((year) => String(year)).join('|')}
        data-search={`${section.subject} ${section.professor} ${section.room} ${section.group}`.toLowerCase()}
        aria-pressed={section.majors.includes(initialMajor)}
      >
        <div class="section-card-top">
          <h3>{section.subject}</h3>
          <span class="section-check">Incluida</span>
        </div>
        <p class="section-professor">{section.professor}</p>
        <div class="section-meta">
          <span>G{section.group}</span>
          <span>{section.room}</span>
          <span>{section.academicYears.map((year) => formatAcademicYear(year)).join(' · ')}</span>
        </div>
      </button>
    ))}
  </div>
</aside>

<style>
  .catalog {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: 2rem;
    max-height: calc(100vh - 4rem);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .catalog-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .catalog-count {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
  }

  .search-box input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    transition: border-color 0.2s ease;
  }

  .search-box input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .catalog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    overflow-y: auto;
    padding-right: var(--space-1);
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .section-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .section-card:hover {
    border-color: var(--color-primary);
    background: var(--color-surface-muted);
  }

  .section-card.is-selected {
    border-color: var(--color-primary);
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 10%, var(--color-surface)), var(--color-surface));
    box-shadow: var(--shadow-sm);
  }

  .section-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .section-card h3 {
    font-size: var(--font-size-sm);
    margin: 0;
    line-height: 1.3;
  }

  .section-check {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
    padding: 2px 6px;
    border-radius: var(--radius-full);
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.2s ease;
  }

  .is-selected .section-check {
    opacity: 1;
    transform: scale(1);
  }

  .section-professor {
    font-size: var(--font-size-xs);
    color: var(--color-text-soft);
    margin: 0;
  }

  .section-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
  }

  .section-meta span {
    font-size: 10px;
    padding: 2px 6px;
    background: var(--color-surface-muted);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-weight: var(--font-weight-semibold);
  }
</style>
