---
import Card from "@/components/UI/Card.astro";

interface Props {
  professorNames: string[];
  professorSchedules: Record<string, any>;
  initialProfessor: string;
}

const { professorNames, professorSchedules, initialProfessor } = Astro.props;

const getEntries = (name: string) => {
  const professor = professorSchedules[name];
  if (!professor) return [];
  return Object.values(professor.by_day).flat() as any[];
};
---

<Card as="aside" class="catalog" padding="lg">
  <div class="catalog-head">
    <div>
      <p class="eyebrow">Catálogo</p>
      <h2>Docentes</h2>
    </div>
    <p class="catalog-count text-soft">
      <span id="visible-professor-count">{professorNames.length}</span> disponibles
    </p>
  </div>

  <label class="search-box">
    <span class="sr-only">Buscar profesor</span>
    <input
      id="professor-search"
      type="search"
      placeholder="Buscar por nombre"
    />
  </label>

  <div class="catalog-list" data-professor-list>
    {
      professorNames.map((name) => {
        const entries = getEntries(name);
        const days = new Set(entries.map((entry) => entry.day)).size;
        const subjects = new Set(entries.map((entry) => entry.subject)).size;

        return (
          <button
            type="button"
            class:list={[
              "section-card",
              { "is-selected": name === initialProfessor },
            ]}
            data-professor-button
            data-professor={name}
            data-search={name.toLowerCase()}
            aria-pressed={name === initialProfessor}
          >
            <div class="section-card-top">
              <div>
                <h3>{name}</h3>
                <p class="section-subtitle">
                  {subjects} materias en {days} días
                </p>
              </div>
              <div class="workload-indicator">
                {["L", "M", "X", "J", "V"].map((code) => {
                  const count = entries.filter((e) => e.day === code).length;
                  return (
                    <span
                      class:list={[
                        "workload-dot",
                        { "has-load": count > 0, "high-load": count > 3 },
                      ]}
                      title={`${count} sesiones`}
                    />
                  );
                })}
              </div>
            </div>
          </button>
        );
      })
    }
  </div>
</Card>

<style>
  .catalog {
    position: sticky;
    top: var(--space-8);
    max-height: calc(100vh - var(--space-16));
    transition: all var(--transition-spring);
  }

  .catalog-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: flex-end;
    margin-bottom: var(--space-4);
  }

  .catalog-count {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .search-box input {
    width: 100%;
    min-height: 48px;
    padding: 0 var(--space-3);
    border-radius: var(--radius-md);
    border: var(--border-width-sm) solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .catalog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    overflow-y: auto;
    padding-right: var(--space-2);
  }

  .section-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .section-card.is-selected {
    border-color: var(--color-primary);
    border-width: 2px;
    box-shadow: var(--shadow-lg);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 5%, var(--color-surface) 95%),
      var(--color-surface)
    );
  }

  .section-subtitle {
    margin: 0;
    font-size: 11px;
    color: var(--color-text-soft);
  }

  .workload-indicator {
    display: flex;
    gap: 3px;
    margin-top: var(--space-1);
  }

  .workload-dot {
    width: var(--workload-dot-size);
    height: var(--workload-dot-size);
    border-radius: var(--radius-full);
    background: var(--color-surface-muted);
    transition: all var(--transition-base);
  }

  .workload-dot.has-load {
    background: var(--color-text-soft);
  }

  .workload-dot.high-load {
    background: var(--color-primary);
    box-shadow: 0 0 4px var(--color-primary);
  }

  .section-card-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .section-card h3 {
    margin: 0;
    font-size: var(--font-size-md);
    line-height: 1.2;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1100px) {
    .catalog {
      position: static;
      max-height: none;
    }
  }
</style>
