---
import Card from '@/components/UI/Card.astro';
import type { ProfessorSchedule, ScheduleEntry } from '@/lib/schedules';

interface Props {
  professorNames: string[];
  professorSchedules: Record<string, ProfessorSchedule>;
  initialProfessor: string;
}

const { professorNames, professorSchedules, initialProfessor } = Astro.props;

const PAGE_SIZE = 6;
const totalPages = Math.ceil(professorNames.length / PAGE_SIZE);

const getEntries = (name: string): ScheduleEntry[] => {
  const professor = professorSchedules[name];
  if (!professor) return [];
  return Object.values(professor.by_day).flat();
};

function getPageNumbers(current: number, total: number): (number | null)[] {
  const pages: (number | null)[] = [];
  if (total <= 7) {
    for (let i = 1; i <= total; i++) pages.push(i);
    return pages;
  }
  pages.push(1);
  if (current > 3) pages.push(null);
  const start = Math.max(2, current - 1);
  const end = Math.min(total - 1, current + 1);
  for (let i = start; i <= end; i++) pages.push(i);
  if (current < total - 2) pages.push(null);
  pages.push(total);
  return pages;
}
---

<Card
  as="aside"
  class="catalog"
  padding="lg"
  data-initial-professor={initialProfessor}
>
  <div class="catalog-head">
    <div>
      <p class="eyebrow">Catálogo</p>
      <h2>Docentes</h2>
    </div>
    <p class="catalog-count text-soft">
      <span id="visible-professor-count">{professorNames.length}</span> disponibles
    </p>
  </div>

  <label class="search-box">
    <span class="sr-only">Buscar profesor</span>
    <input
      id="professor-search"
      type="search"
      placeholder="Buscar por nombre"
    />
  </label>

  <div class="catalog-list" data-professor-list data-page="1">
    {
      professorNames.map((name) => {
        const entries = getEntries(name);
        const days = new Set(entries.map((entry) => entry.day)).size;
        const subjects = new Set(entries.map((entry) => entry.subject)).size;
        const idx = professorNames.indexOf(name);
        const page = Math.floor(idx / PAGE_SIZE) + 1;

        return (
          <button
            type="button"
            class:list={[
              'section-card',
              { 'is-selected': name === initialProfessor },
              { 'is-page-hidden': page > 1 },
            ]}
            data-professor-button
            data-professor={name}
            data-search={name.toLowerCase()}
            data-page-group={page}
            aria-pressed={name === initialProfessor}
          >
            <div class="section-card-top">
              <div>
                <h4>{name}</h4>
                <p class="section-subtitle">
                  {subjects} materias en {days} días
                </p>
              </div>
              <div class="workload-indicator">
                {['L', 'M', 'X', 'J', 'V'].map((code) => {
                  const count = entries.filter((e) => e.day === code).length;
                  return (
                    <span
                      class:list={[
                        'workload-dot',
                        { 'has-load': count > 0, 'high-load': count > 3 },
                      ]}
                      title={`${count} sesiones`}
                    />
                  );
                })}
              </div>
            </div>
          </button>
        );
      })
    }
  </div>

  {
    totalPages > 1 && (
      <nav class="pagination-nav" data-pagination data-total-pages={totalPages}>
        <button
          type="button"
          class="page-btn page-prev"
          data-page-action="prev"
          disabled
          aria-label="Página anterior"
        >
          <span>‹</span>
        </button>

        {getPageNumbers(1, totalPages).map((p) => {
          if (p === null) return <span class="page-ellipsis">…</span>;
          return (
            <button
              type="button"
              class:list={['page-btn', { 'is-active': p === 1 }]}
              data-page-number={p}
            >
              {p}
            </button>
          );
        })}

        <button
          type="button"
          class="page-btn page-next"
          data-page-action="next"
          aria-label="Página siguiente"
        >
          <span>›</span>
        </button>
      </nav>
    )
  }
</Card>

<style>
  .catalog {
    position: sticky;
    top: var(--space-8);
    max-height: calc(100vh - var(--space-16));
    transition: all var(--transition-spring);
  }

  .catalog-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: flex-end;
    margin-bottom: var(--space-4);
  }

  .catalog-count {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .search-box input {
    width: 100%;
    min-height: 48px;
    padding: 0 var(--space-3);
    border-radius: var(--radius-md);
    border: var(--border-width-sm) solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .catalog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    overflow-y: auto;
    padding-right: var(--space-2);
  }

  .section-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    border: var(--border-width-sm) solid var(--color-border);
    background: var(--color-surface);
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .section-card.is-page-hidden {
    display: none;
  }

  .section-card.is-selected {
    border-color: var(--color-primary);
    border-width: var(--border-width-md);
    box-shadow: var(--shadow-lg);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 5%, var(--color-surface) 95%),
      var(--color-surface)
    );
  }

  .section-subtitle {
    margin: 0;
    font-size: 11px;
    color: var(--color-text-soft);
  }

  .workload-indicator {
    display: flex;
    gap: 3px;
    margin-top: var(--space-1);
  }

  .workload-dot {
    width: var(--workload-dot-size);
    height: var(--workload-dot-size);
    border-radius: var(--radius-full);
    background: var(--color-surface-muted);
    transition: all var(--transition-base);
  }

  .workload-dot.has-load {
    background: var(--color-text-soft);
  }

  .workload-dot.high-load {
    background: var(--color-primary);
    box-shadow: 0 0 4px var(--color-primary);
  }

  .section-card-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .section-card h3 {
    margin: 0;
    font-size: var(--font-size-md);
    line-height: 1.2;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Pagination ── */
  .pagination-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: var(--border-width-sm) solid var(--color-border-soft);
  }

  .page-btn {
    min-width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: var(--border-width-sm) solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text-soft);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: all var(--transition-base);
    padding: 0 6px;
  }

  .page-btn:hover:not(:disabled) {
    background: var(--color-surface-muted);
    border-color: var(--color-text-muted);
  }

  .page-btn.is-active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .page-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .page-ellipsis {
    min-width: 24px;
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
  }

  .page-prev span,
  .page-next span {
    font-size: var(--font-size-lg);
    line-height: 1;
  }

  @media (max-width: 1100px) {
    .catalog {
      position: static;
      max-height: none;
    }
  }
</style>
