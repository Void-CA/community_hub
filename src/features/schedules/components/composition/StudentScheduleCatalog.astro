---
import { formatAcademicYear, groupSectionsBySubject } from "@/lib/schedules";
import type { ScheduleSection } from "@/lib/schedules";
import Badge from "@/components/UI/Badge.astro";
import Card from "@/components/UI/Card.astro";

interface Props {
  allSections: ScheduleSection[];
  initialMajor: string;
  initialYear: number;
  initialVisibleSections: number;
}

const { allSections, initialMajor, initialYear, initialVisibleSections } =
  Astro.props;

const groupedSubjects = groupSectionsBySubject(allSections);
---

<Card as="aside" class="catalog" padding="lg">
  <div class="catalog-head">
    <div>
      <p class="eyebrow">Explorador</p>
      <h2>Asignaturas</h2>
    </div>
    <p class="catalog-count text-soft">
      <span id="visible-section-count">{initialVisibleSections}</span> opciones
    </p>
  </div>

  <label class="search-box">
    <span class="sr-only">Buscar</span>
    <input
      id="section-search"
      type="search"
      placeholder="Buscar materia o profesor"
    />
  </label>

  <div class="catalog-list">
    {
      groupedSubjects.map((subject) => (
        <div class="subject-group" data-subject-container>
          <div class="subject-info">
            <h3>{subject.subject}</h3>
            <span class="option-count">{subject.options.length} grupos</span>
          </div>
          
          <div class="group-selector">
            {subject.options.map((option) => {
              const section = option.section;
              return (
                <button
                  type="button"
                  class:list={[
                    "group-button",
                    {
                      "is-selected":
                        section.majors.includes(initialMajor) &&
                        (initialYear <= 0 ||
                          section.academicYears.includes(initialYear)),
                    },
                  ]}
                  data-section-toggle
                  data-section-id={section.id}
                  data-subject={section.subject}
                  data-major-list={section.majors
                    .map((m) => m.toLowerCase())
                    .join("|")}
                  data-year-list={section.academicYears
                    .map((y) => String(y))
                    .join("|")}
                  data-search={`${section.subject} ${section.professor} ${section.room} ${section.group}`.toLowerCase()}
                  aria-pressed={section.majors.includes(initialMajor)}
                  title={`${section.professor} · ${section.room}`}
                >
                  G{section.group}
                </button>
              );
            })}
          </div>
        </div>
      ))
    }
  </div>
</Card>

<style>
  .catalog {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: 2rem;
    max-height: calc(100vh - 4rem);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .catalog-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .catalog-count {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
  }

  .search-box input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    transition: border-color 0.2s ease;
  }

  .search-box input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px
      color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .catalog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    overflow-y: auto;
    padding-right: var(--space-1);
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .subject-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-3);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: all 0.2s ease;
  }

  .subject-group:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }

  .subject-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-border-soft);
    padding-bottom: var(--space-2);
  }

  .subject-info h3 {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    max-width: 70%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .option-count {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-muted);
    background: var(--color-surface-muted);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
  }

  .group-selector {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .group-button {
    flex: 1;
    min-width: 3rem;
    padding: var(--space-2) var(--space-1);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-soft);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .group-button:hover {
    background: var(--color-surface-muted);
    border-color: var(--color-primary);
  }

  .group-button.is-selected {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 30%, transparent);
    transform: translateY(-1px) scale(1.05);
  }

  .group-button.is-ghosted {
    opacity: 0.3;
    filter: grayscale(1);
    cursor: not-allowed;
  }

  .group-button.is-compatible {
    border-color: var(--color-success);
    background: color-mix(in srgb, var(--color-success) 5%, var(--color-surface));
  }

</style>
