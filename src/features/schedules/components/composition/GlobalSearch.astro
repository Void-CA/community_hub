---
import Card from '@/components/UI/Card.astro';
import {
  resolveScheduleDatasetByYearTerm,
  buildScheduleSections,
} from '@/lib/schedules';

// For simplicity, we'll load the current dataset to provide search suggestions
const dataset = resolveScheduleDatasetByYearTerm();
const professors = Object.keys(dataset.professorSchedules).sort();
const sections = buildScheduleSections(dataset.entries);
const subjects = [...new Set(sections.map((s) => s.subject))].sort();
---

<div class="global-search" id="global-search-container">
  <div class="search-input-wrapper">
    <input
      type="text"
      id="global-schedule-search"
      placeholder="Busca un profesor, materia o carrera..."
      autocomplete="off"
    />
    <div class="search-icon">
      <svg
        viewBox="0 0 24 24"
        width="18"
        height="18"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
    </div>
  </div>

  <div class="search-results hidden" id="search-results">
    <Card padding="sm" class="results-card">
      <div class="results-list" id="results-list">
        <!-- Results will be injected here -->
      </div>
    </Card>
  </div>
</div>

<script is:inline define:vars={{ professors, subjects }}>
  const input = document.getElementById('global-schedule-search');
  const resultsContainer = document.getElementById('search-results');
  const resultsList = document.getElementById('results-list');

  const MAX_RESULTS = 8;

  input?.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase().trim();

    if (query.length < 2) {
      resultsContainer?.classList.add('hidden');
      return;
    }

    const matchedProfessors = professors
      .filter((p) => p.toLowerCase().includes(query))
      .slice(0, MAX_RESULTS)
      .map((p) => ({
        name: p,
        type: 'profesor',
        url: `/campus/schedules/professors?search=${encodeURIComponent(p)}`,
      }));

    const matchedSubjects = subjects
      .filter((s) => s.toLowerCase().includes(query))
      .slice(0, MAX_RESULTS)
      .map((s) => ({
        name: s,
        type: 'materia',
        url: `/campus/schedules/students?search=${encodeURIComponent(s)}`,
      }));

    const allResults = [...matchedProfessors, ...matchedSubjects].slice(
      0,
      MAX_RESULTS,
    );

    if (allResults.length === 0) {
      resultsContainer?.classList.add('hidden');
      return;
    }

    renderResults(allResults);
    resultsContainer?.classList.remove('hidden');
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (
      !document.getElementById('global-search-container')?.contains(e.target)
    ) {
      resultsContainer?.classList.add('hidden');
    }
  });

  function renderResults(results) {
    if (!resultsList) return;
    resultsList.innerHTML = results
      .map(
        (res) => `
      <a href="${res.url}" class="search-result-item">
        <span class="result-name">${res.name}</span>
        <span class="result-badge ${res.type}">${res.type}</span>
      </a>
    `,
      )
      .join('');
  }
</script>

<style>
  .global-search {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: var(--space-8) auto;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  input {
    width: 100%;
    height: 3.5rem;
    padding: 0 var(--space-6) 0 3.5rem;
    background: var(--color-surface);
    border: var(--border-width-md) solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--font-size-lg);
    color: var(--color-text);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
  }

  input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: var(--focus-ring-lg), var(--shadow-lg);
  }

  .search-icon {
    position: absolute;
    left: 1.25rem;
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-results {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    right: 0;
    z-index: 100;
  }

  .search-results.hidden {
    display: none;
  }

  .results-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .search-result-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    transition: background var(--transition-base);
  }

  .search-result-item:hover {
    background: var(--color-surface-muted);
  }

  .result-name {
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
  }

  .result-badge {
    font-size: var(--font-size-2xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }

  .result-badge.profesor {
    background: color-mix(
      in srgb,
      var(--color-primary) 10%,
      var(--color-surface)
    );
    color: var(--color-primary);
  }

  .result-badge.materia {
    background: color-mix(
      in srgb,
      var(--color-accent) 10%,
      var(--color-surface)
    );
    color: var(--color-accent);
  }
</style>
