---
import ScheduleTile from "../domain/ScheduleTile.astro";
import Legend from "./Legend.astro";
import {
  formatBlock,
  buildTimelineCellIndex,
  getBlockIndex,
} from "@/lib/schedules";
import type { ScheduleSection } from "@/lib/schedules";
import Card from "@/components/UI/Card.astro";

interface DayItem {
  code: string;
  label: string;
}

interface Props {
  activeDays: DayItem[];
  scheduleBlocks: readonly any[]; // Changed from string[]
  allSections: ScheduleSection[];
}

const { activeDays, scheduleBlocks, allSections } = Astro.props;
const cellIndex = buildTimelineCellIndex(allSections);
---

<Card as="main" class="timeline" padding="lg">
  <div class="timeline-header-actions">
    <div>
      <p class="eyebrow">Visualización</p>
      <h2>Mi Horario</h2>
    </div>
    <button id="zen-mode-toggle" class="zen-button">Vista dedicada</button>
  </div>

  <div class="timeline-scroll">
    <div
      class="timeline-grid"
      style={`grid-template-columns: 4rem repeat(${activeDays.length}, 1fr);`}
    >
      <!-- 1. Header Corner -->
      <div class="timeline-corner"></div>
      
      <!-- 2. Day Headers -->
      {
        activeDays.map((day) => (
          <div class="timeline-day">
            <span>{day.label}</span>
          </div>
        ))
      }

      <!-- 3. Time Axis & Background Cells -->
      {
        scheduleBlocks.map((block, rowIndex) => {
          const isBreak = block.type === "break";
          const rowStart = rowIndex + 2; // +1 for header, +1 for 1-based index

          return (
            <Fragment>
              <!-- Time Label -->
              <div
                class:list={["timeline-time", { "is-break": isBreak }]}
                style={`grid-row: ${rowStart}; grid-column: 1;`}
              >
                <span class="slot-label">{block.label || ""}</span>
                <span class="slot-range">{block.range.split(" ")[0]}</span>
              </div>

              <!-- Background Row -->
              {activeDays.map((_, colIndex) => (
                <div
                  class:list={["timeline-bg-cell", { "is-break": isBreak }]}
                  style={`grid-row: ${rowStart}; grid-column: ${colIndex + 2};`}
                >
                  {isBreak && colIndex === 0 && (
                    <span class="break-label-abs">{block.label}</span>
                  )}
                </div>
              ))}
            </Fragment>
          );
        })
      }

      <!-- 4. Real Tiles -->
      {
        allSections.map((section) => 
          section.entries.map((entry) => {
            const startIdx = getBlockIndex(entry.start_block);
            const endIdx = getBlockIndex(entry.end_block);
            const dayIdx = activeDays.findIndex(d => d.code === entry.day);
            
            if (dayIdx === -1 || startIdx === -1) return null;

            const rowStart = startIdx + 2;
            const rowSpan = endIdx - startIdx + 1;
            const colStart = dayIdx + 2;

            return (
              <div
                class="timeline-tile-container"
                data-section-id={section.id}
                data-day={entry.day}
                data-block={entry.start_block}
                style={`grid-row: ${rowStart} / span ${rowSpan}; grid-column: ${colStart}; z-index: 10;`}
                hidden
              >
                <ScheduleTile
                  entry={entry}
                  sectionId={section.id}
                  label={entry.subject}
                />
              </div>
            );
          })
        )
      }
    </div>
    <Legend />
  </div>
</Card>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .timeline-header-actions {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: var(--space-2);
  }

  .zen-button {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .zen-button:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .zen-button.is-active {
    background: var(--color-primary);
    color: white;
  }

  .timeline-scroll {
    overflow: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    position: relative;
    max-height: calc(100vh - 220px); /* Adapt to available space */
  }

  .timeline-grid {
    display: grid;
    gap: 1px;
    background: var(--color-border);
    min-width: 100%;
    --cell-height: 3.8rem;
  }

  .timeline-grid > div {
    background: var(--color-surface);
  }

  .timeline-corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 30;
    background: var(--color-surface-muted) !important;
  }

  .timeline-day {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    background: var(--color-surface-muted) !important;
    border-bottom: 2px solid var(--color-primary);
  }

  .timeline-day span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .timeline-time {
    position: sticky;
    left: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    background: var(--color-surface-muted) !important;
    border-right: 1px solid var(--color-border);
    gap: 0;
  }

  .timeline-time.is-break {
    background: color-mix(
      in srgb,
      var(--color-surface-muted) 80%,
      var(--color-bg)
    ) !important;
  }

  .timeline-time.is-empty,
  .timeline-cell.is-empty {
    min-height: 1.5rem !important;
    height: 1.5rem !important;
  }

  .slot-label {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .slot-range {
    font-size: 9px;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace;
  }

  .timeline-bg-cell {
    min-height: var(--cell-height);
    background: var(--color-surface);
    position: relative;
  }

  .timeline-bg-cell.is-break {
    background: repeating-linear-gradient(
      -45deg,
      var(--color-surface-muted),
      var(--color-surface-muted) 4px,
      color-mix(in srgb, var(--color-surface-muted) 80%, var(--color-bg)) 4px,
      color-mix(in srgb, var(--color-surface-muted) 80%, var(--color-bg)) 8px
    ) !important;
  }

  .timeline-tile-container {
    padding: 3px;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .timeline-tile-container[hidden] {
    display: none !important;
  }

  .break-label-abs {
    position: absolute;
    top: 50%;
    left: 50vw; /* Center horizontally in the grid */
    transform: translate(-50%, -50%);
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    opacity: 0.4;
    white-space: nowrap;
    pointer-events: none;
    z-index: 5;
  }

  @media (max-width: 768px) {
    .timeline-time span {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }
</style>
