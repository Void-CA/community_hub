---
import ScheduleTile from "../domain/ScheduleTile.astro";
import {
  formatBlock,
  buildTimelineCellIndex,
  getBlockIndex,
} from "@/lib/schedules";
import type { ScheduleSection } from "@/lib/schedules";
import Card from "@/components/UI/Card.astro";

interface DayItem {
  code: string;
  label: string;
}

interface Props {
  activeDays: DayItem[];
  scheduleBlocks: readonly any[]; // Changed from string[]
  allSections: ScheduleSection[];
}

const { activeDays, scheduleBlocks, allSections } = Astro.props;
const cellIndex = buildTimelineCellIndex(allSections);
---

<Card as="main" class="timeline" padding="lg">
  <div class="timeline-header-actions">
    <div>
      <p class="eyebrow">Visualización</p>
      <h2>Mi Horario</h2>
    </div>
    <button id="zen-mode-toggle" class="zen-button">Vista dedicada</button>
  </div>

  <div class="timeline-scroll">
    <div
      class="timeline-grid"
      style={`grid-template-columns: 4rem repeat(${activeDays.length}, 1fr);`}
    >
      <div class="timeline-corner"></div>
      {
        activeDays.map((day) => (
          <div class="timeline-day">
            <span>{day.label}</span>
          </div>
        ))
      }

      {
        scheduleBlocks.map((block) => {
          const isBreak = block.type === "break";
          const blockIndex = getBlockIndex(block.label);
          const occupied = allSections.some((section) =>
            section.entries.some((entry) => {
              const start = getBlockIndex(entry.start_block);
              const end = getBlockIndex(entry.end_block);
              return blockIndex >= start && blockIndex <= end;
            }),
          );

          return (
            <Fragment>
              <div
                class:list={[
                  "timeline-time",
                  { "is-break": isBreak, "is-empty": isBreak && !occupied },
                ]}
              >
                <span class="slot-label">{block.label || ""}</span>
                <span class="slot-range">{block.range.split(' ')[0]}</span>
              </div>
              {activeDays.map((day) => {
                // Find tiles that START in this block
                const tilesStartingHere = (cellIndex.get(`${day.code}::${block.label}`) ?? [])
                  .filter(t => getBlockIndex(t.entry.start_block) === blockIndex);

                // Check if this cell is part of a span from a PREVIOUS block
                const isCoveredBySpan = (cellIndex.get(`${day.code}::${block.label}`) ?? [])
                  .some(t => getBlockIndex(t.entry.start_block) < blockIndex);

                if (isCoveredBySpan) return null;

                return (
                  <div
                    class:list={[
                      "timeline-cell",
                      {
                        "is-break": isBreak,
                        "is-empty": isBreak && !occupied,
                        "has-multiple": tilesStartingHere.length > 1,
                      },
                    ]}
                    data-day={day.code}
                    data-block={block.label}
                  >
                    {isBreak && !occupied ? (
                      <span class="break-label">{block.label}</span>
                    ) : (
                      tilesStartingHere.map(({ entry, sectionId, rowSpan }) => (
                        <ScheduleTile
                          entry={entry}
                          sectionId={sectionId}
                          label={entry.subject}
                          style={
                            rowSpan && rowSpan > 1
                              ? `grid-row: span ${rowSpan}; min-height: calc(${rowSpan} * (var(--cell-height) + 1px) - 1px); z-index: 1;`
                              : ""
                          }
                        />
                      ))
                    )}
                  </div>
                );
              })}
            </Fragment>
          );
        })
      }
    </div>
  </div>
</Card>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .timeline-header-actions {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: var(--space-2);
  }

  .zen-button {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .zen-button:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .zen-button.is-active {
    background: var(--color-primary);
    color: white;
  }

  .timeline-scroll {
    overflow: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    position: relative;
    max-height: calc(100vh - 220px); /* Adapt to available space */
  }

  .timeline-grid {
    display: grid;
    gap: 1px;
    background: var(--color-border);
    min-width: 100%;
    --cell-height: 3.8rem;
  }

  .timeline-grid > div {
    background: var(--color-surface);
  }

  .timeline-corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 30;
    background: var(--color-surface-muted) !important;
  }

  .timeline-day {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    background: var(--color-surface-muted) !important;
    border-bottom: 2px solid var(--color-primary);
  }

  .timeline-day span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .timeline-time {
    position: sticky;
    left: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    background: var(--color-surface-muted) !important;
    border-right: 1px solid var(--color-border);
    gap: 0;
  }

  .timeline-time.is-break {
    background: color-mix(
      in srgb,
      var(--color-surface-muted) 80%,
      var(--color-bg)
    ) !important;
  }

  .timeline-time.is-empty,
  .timeline-cell.is-empty {
    min-height: 1.5rem !important;
    height: 1.5rem !important;
  }

  .slot-label {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .slot-range {
    font-size: 9px;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }

  .timeline-cell {
    min-height: var(--cell-height);
    padding: 2px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    transition: background-color 0.2s ease;
  }

  .timeline-cell.has-multiple {
    flex-direction: row;
    flex-wrap: nowrap;
  }

  .timeline-cell.has-multiple > * {
    flex: 1;
    min-width: 0;
  }

  .timeline-cell.is-break {
    background: repeating-linear-gradient(
      -45deg,
      var(--color-surface-muted),
      var(--color-surface-muted) 4px,
      color-mix(in srgb, var(--color-surface-muted) 80%, var(--color-bg)) 4px,
      color-mix(in srgb, var(--color-surface-muted) 80%, var(--color-bg)) 8px
    ) !important;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    border: none;
  }

  .break-label {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  .timeline-cell:hover {
    background: var(--color-surface-muted) !important;
  }

  .timeline-cell:empty {
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      color-mix(in srgb, var(--color-surface-muted) 40%, transparent) 10px,
      color-mix(in srgb, var(--color-surface-muted) 40%, transparent) 20px
    );
  }

  @media (max-width: 768px) {
    .timeline-time span {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }
</style>
