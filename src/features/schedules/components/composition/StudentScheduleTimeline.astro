---
import BaseTimeline from './BaseTimeline.astro';
import ScheduleTile from '../domain/ScheduleTile.astro';
import Legend from './Legend.astro';
import { getBlockIndex } from '@/lib/schedules';
import type { ScheduleSection } from '@/lib/schedules';

interface DayItem {
  code: string;
  label: string;
}

interface Props {
  activeDays: DayItem[];
  scheduleBlocks: { type: string; label: string; range: string }[];
  allSections: ScheduleSection[];
}

const { activeDays, scheduleBlocks, allSections } = Astro.props;
---

<BaseTimeline
  title="Mi Horario"
  activeDays={activeDays}
  scheduleBlocks={scheduleBlocks}
>
  <Fragment slot="tiles">
    {
      allSections.map((section) =>
        section.entries.map((entry) => {
          const startIdx = getBlockIndex(entry.start_block);
          const endIdx = getBlockIndex(entry.end_block);
          const dayIdx = activeDays.findIndex((d) => d.code === entry.day);

          if (dayIdx === -1 || startIdx === -1) return null;

          const rowStart = startIdx + 2;
          const rowSpan = endIdx - startIdx + 1;
          const colStart = dayIdx + 2;

          return (
            <div
              class="timeline-tile-container"
              data-section-id={section.id}
              data-day={entry.day}
              data-block={entry.start_block}
              style={`grid-row: ${rowStart} / span ${rowSpan}; grid-column: ${colStart}; z-index: 10;`}
              hidden
            >
              <ScheduleTile
                entry={entry}
                sectionId={section.id}
                label={entry.subject}
                variant="student"
              />
            </div>
          );
        }),
      )
    }
  </Fragment>
  <Legend />
</BaseTimeline>
