---
interface LegendItem {
  color?: string;
  label: string;
  description: string;
  isPattern?: boolean;
}

const generalItems: LegendItem[] = [
  {
    label: 'Materia',
    description: 'Cada materia tiene un color único asignado automáticamente.',
    color: 'var(--color-primary)',
  },
  {
    label: 'Conflicto',
    description: 'Aviso de solapamiento entre dos o más clases.',
    color: 'var(--color-error)',
  },
  {
    label: 'Receso / Almuerzo',
    description: 'Espacios entre bloques académicos.',
    isPattern: true,
  },
];
---

<div class="schedule-legend">
  <p class="legend-title">Guía de Visualización</p>
  <div class="legend-grid">
    {
      generalItems.map((item) => (
        <div class="legend-item">
          <div
            class:list={['legend-swatch', { 'is-pattern': item.isPattern }]}
            style={item.color ? `background-color: ${item.color}` : ''}
          />
          <div class="legend-info">
            <span class="legend-label">{item.label}</span>
            <span class="legend-desc">{item.description}</span>
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .schedule-legend {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    margin-top: var(--space-4);
  }

  .legend-title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .legend-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .legend-item {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .legend-swatch {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .legend-swatch.is-pattern {
    background: repeating-linear-gradient(
      -45deg,
      var(--color-border),
      var(--color-border) var(--break-stripe-size),
      transparent var(--break-stripe-size),
      transparent calc(var(--break-stripe-size) * 2)
    );
    border: var(--border-width-sm) solid var(--color-border);
  }

  .legend-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .legend-label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .legend-desc {
    font-size: var(--font-size-2xs);
    color: var(--color-text-muted);
    line-height: 1.3;
  }
</style>
