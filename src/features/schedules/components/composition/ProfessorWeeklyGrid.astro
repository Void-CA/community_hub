---
import Card from "@/components/UI/Card.astro";
import ScheduleTile from "@/features/schedules/components/domain/ScheduleTile.astro";
import Legend from "./Legend.astro";
import { getBlockIndex, dayNames } from "@/lib/schedules";

interface Props {
  activeDays: readonly any[];
  scheduleBlocks: readonly any[];
  professorSchedules: Record<string, any>;
  professorNames: string[];
}

const { activeDays, scheduleBlocks, professorSchedules, professorNames } =
  Astro.props;

const getEntries = (name: string) => {
  const professor = professorSchedules[name];
  if (!professor) return [];
  return dayNames.flatMap(({ code }) => professor.by_day[code] ?? []);
};

const getTilesForCell = (dayCode: string, blockLabel: string) => {
  const current = getBlockIndex(blockLabel);

  return professorNames.flatMap((name) =>
    getEntries(name)
      .filter((entry) => {
        if (entry.day !== dayCode) return false;
        const start = getBlockIndex(entry.start_block);
        return current === start;
      })
      .map((entry) => {
        const start = getBlockIndex(entry.start_block);
        const end = getBlockIndex(entry.end_block);
        return { entry, professorName: name, rowSpan: end - start + 1 };
      }),
  );
};

const isOccupied = (blockLabel: string) => {
  const current = getBlockIndex(blockLabel);
  return professorNames.some((name) =>
    getEntries(name).some((entry) => {
      const start = getBlockIndex(entry.start_block);
      const end = getBlockIndex(entry.end_block);
      return current >= start && end >= current;
    }),
  );
};
---

<Card as="main" class="timeline" padding="lg">
  <div class="timeline-head">
    <div>
      <p class="eyebrow">Visualización</p>
      <h2>Grilla Semanal</h2>
    </div>
    <div class="timeline-actions">
      <p class="text-soft">Solo se muestra el docente seleccionado.</p>
      <button id="zen-mode-toggle" class="zen-button">Vista dedicada</button>
    </div>
  </div>

  <div class="timeline-scroll">
    <div
      class="timeline-grid"
      style={`grid-template-columns: 4rem repeat(${activeDays.length}, 1fr);`}
    >
      <!-- 1. Header Corner -->
      <div class="timeline-corner"></div>

      <!-- 2. Day Headers -->
      {
        activeDays.map((day) => (
          <div class="timeline-day">
            <span>{day.label}</span>
          </div>
        ))
      }

      <!-- 3. Time Axis & Background Cells -->
      {
        scheduleBlocks.map((block, rowIndex) => {
          const isBreak = block.type === "break";
          const rowStart = rowIndex + 2;

          return (
            <Fragment>
              <!-- Time Label -->
              <div
                class:list={["timeline-time", { "is-break": isBreak }]}
                style={`grid-row: ${rowStart}; grid-column: 1;`}
              >
                <span class="slot-label">{block.label || ""}</span>
                <span class="slot-range">{block.range.split(" ")[0]}</span>
              </div>

              <!-- Background Cells -->
              {activeDays.map((_, colIndex) => (
                <div
                  class:list={["timeline-bg-cell", { "is-break": isBreak }]}
                  style={`grid-row: ${rowStart}; grid-column: ${colIndex + 2};`}
                >
                  {isBreak && colIndex === 0 && (
                    <span class="break-label-abs">{block.label}</span>
                  )}
                </div>
              ))}
            </Fragment>
          );
        })
      }

      <!-- 4. Professor Tiles (Absolute Positioning) -->
      {
        professorNames.map((name) => 
          getEntries(name).map((entry) => {
            const startIdx = getBlockIndex(entry.start_block);
            const endIdx = getBlockIndex(entry.end_block);
            const dayIdx = activeDays.findIndex(d => d.code === entry.day);

            if (dayIdx === -1 || startIdx === -1) return null;

            const rowStart = startIdx + 2;
            const rowSpan = endIdx - startIdx + 1;
            const colStart = dayIdx + 2;

            return (
              <div
                class="timeline-tile-container"
                data-section-id={name}
                style={`grid-row: ${rowStart} / span ${rowSpan}; grid-column: ${colStart}; z-index: 10;`}
                hidden
              >
                <ScheduleTile
                  entry={entry}
                  sectionId={name}
                  label={entry.subject}
                />
              </div>
            );
          })
        )
      }
    </div>
    <Legend />
  </div>

  <div class="timeline-empty" id="timeline-empty" hidden>
    <h3>No hay horarios para mostrar.</h3>
    <p class="text-soft">Selecciona un docente del catálogo lateral.</p>
  </div>
</Card>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .timeline-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: flex-end;
    margin-bottom: var(--space-2);
  }

  .timeline-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .zen-button {
    background: var(--color-surface-muted);
    border: var(--border-width-sm) solid var(--color-border);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .zen-button:hover,
  .zen-button.is-active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .timeline-scroll {
    overflow: auto;
    border-radius: var(--radius-lg);
    border: var(--border-width-sm) solid var(--color-border);
    background: var(--color-bg);
    position: relative;
    max-height: calc(100vh - 220px);
  }

  .timeline-grid {
    display: grid;
    gap: var(--timeline-grid-gap);
    background: var(--color-border);
    min-width: 100%;
    --cell-height: var(--cell-height);
  }

  .timeline-grid > div {
    background: var(--color-surface);
  }

  .timeline-corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 30;
    background: var(--color-surface-muted) !important;
  }

  .timeline-day {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    background: var(--color-surface-muted) !important;
    border-bottom: var(--border-width-md) solid var(--color-primary);
  }

  .timeline-day span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .timeline-time {
    position: sticky;
    left: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    background: var(--color-surface-muted) !important;
    border-right: var(--border-width-sm) solid var(--color-border);
    gap: 0;
  }

  .timeline-time.is-break {
    background: color-mix(
      in srgb,
      var(--color-surface-muted) 80%,
      var(--color-bg)
    ) !important;
  }

  .slot-label {
    font-size: var(--font-size-2xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .slot-range {
    font-size: var(--font-size-tiny);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    font-family: var(--font-family-mono);
  }

  .timeline-bg-cell {
    min-height: var(--cell-height);
    background: var(--color-surface);
    position: relative;
  }

  .timeline-bg-cell.is-break {
    background: repeating-linear-gradient(
      -45deg,
      var(--color-surface-muted),
      var(--color-surface-muted) var(--break-stripe-size),
      color-mix(in srgb, var(--color-surface-muted) 80%, var(--color-bg)) var(--break-stripe-size),
      color-mix(in srgb, var(--color-surface-muted) 80%, var(--color-bg)) calc(var(--break-stripe-size) * 2)
    ) !important;
  }

  .timeline-tile-container {
    padding: 3px;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .timeline-tile-container[hidden] {
    display: none !important;
  }

  .break-label-abs {
    position: absolute;
    top: 50%;
    left: 50vw;
    transform: translate(-50%, -50%);
    font-size: var(--font-size-2xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    opacity: 0.4;
    white-space: nowrap;
    pointer-events: none;
    z-index: 5;
  }

  .timeline-empty {
    padding: var(--space-8);
    text-align: center;
  }

  .timeline-empty h3 {
    margin-bottom: var(--space-2);
  }

  @media (max-width: 1100px) {
    .timeline-time span {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }
</style>
