---
import Card from "@/components/UI/Card.astro";
import ScheduleTile from "@/features/schedules/components/domain/ScheduleTile.astro";
import { getBlockIndex, dayNames } from "@/lib/schedules";

interface Props {
  activeDays: readonly any[];
  scheduleBlocks: readonly any[];
  professorSchedules: Record<string, any>;
  professorNames: string[];
}

const { activeDays, scheduleBlocks, professorSchedules, professorNames } =
  Astro.props;

const getEntries = (name: string) => {
  const professor = professorSchedules[name];
  if (!professor) return [];
  return dayNames.flatMap(({ code }) => professor.by_day[code] ?? []);
};

const getTilesForCell = (dayCode: string, blockLabel: string) => {
  const current = getBlockIndex(blockLabel);

  return professorNames.flatMap((name) =>
    getEntries(name)
      .filter((entry) => {
        if (entry.day !== dayCode) return false;
        const start = getBlockIndex(entry.start_block);
        return current === start;
      })
      .map((entry) => {
        const start = getBlockIndex(entry.start_block);
        const end = getBlockIndex(entry.end_block);
        return { entry, professorName: name, rowSpan: end - start + 1 };
      }),
  );
};

const isOccupied = (blockLabel: string) => {
  const current = getBlockIndex(blockLabel);
  return professorNames.some((name) =>
    getEntries(name).some((entry) => {
      const start = getBlockIndex(entry.start_block);
      const end = getBlockIndex(entry.end_block);
      return current >= start && current <= end;
    }),
  );
};
---

<Card as="main" class="timeline" padding="lg">
  <div class="timeline-head">
    <div>
      <p class="eyebrow">Visualización</p>
      <h2>Grilla Semanal</h2>
    </div>
    <div class="timeline-actions">
      <p class="text-soft">Solo se muestra el docente seleccionado.</p>
      <button id="zen-mode-toggle" class="zen-button">Vista dedicada</button>
    </div>
  </div>

  <div class="timeline-scroll">
    <div
      class="timeline-grid"
      style={`grid-template-columns: 5rem repeat(${activeDays.length}, minmax(12rem, 1fr));`}
    >
      <div class="timeline-corner"></div>
      {
        activeDays.map((day) => (
          <div class="timeline-day">
            <span>{day.label}</span>
          </div>
        ))
      }

      {
        scheduleBlocks.map((block) => {
          const isBreak = block.type === "break";
          const occupied = isOccupied(block.label);

          return (
            <Fragment>
              <div
                class:list={[
                  "timeline-time",
                  {
                    "is-break": isBreak,
                    "is-empty": isBreak && !occupied,
                  },
                ]}
              >
                <span class="slot-label">{block.label || ""}</span>
                <span class="slot-range">{block.range}</span>
              </div>
              {activeDays.map((day) => {
                const tilesForCell = getTilesForCell(day.code, block.label);

                return (
                  <div
                    class:list={[
                      "timeline-cell",
                      {
                        "is-break": isBreak,
                        "is-empty": isBreak && !occupied,
                      },
                    ]}
                  >
                    {isBreak && !occupied ? (
                      <span class="break-label">{block.label}</span>
                    ) : (
                      tilesForCell.map(({ entry, professorName, rowSpan }) => (
                        <ScheduleTile
                          entry={entry}
                          sectionId={professorName}
                          label={entry.subject}
                          style={
                            rowSpan && rowSpan > 1
                              ? `grid-row: span ${rowSpan}; height: calc(${rowSpan} * (var(--cell-height) + 1px) - 1px);`
                              : ""
                          }
                        />
                      ))
                    )}
                  </div>
                );
              })}
            </Fragment>
          );
        })
      }
    </div>
  </div>

  <div class="timeline-empty" id="timeline-empty" hidden>
    <h3>No hay horarios para mostrar.</h3>
    <p class="text-soft">Selecciona un docente del catálogo lateral.</p>
  </div>
</Card>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .timeline-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: flex-end;
    margin-bottom: var(--space-2);
  }

  .timeline-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .zen-button {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .zen-button:hover,
  .zen-button.is-active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .timeline-scroll {
    overflow: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    position: relative;
    max-height: calc(100vh - 220px); /* Adapt to available space */
  }

  .timeline-grid {
    display: grid;
    gap: 1px;
    background: var(--color-border);
    min-width: 100%;
    --cell-height: 3.8rem;
  }

  .timeline-grid > div {
    background: var(--color-surface);
  }

  .timeline-corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 30;
    background: var(--color-surface-muted) !important;
  }

  .timeline-day {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    background: var(--color-surface-muted) !important;
    border-bottom: 2px solid var(--color-primary);
  }

  .timeline-day span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .timeline-time {
    position: sticky;
    left: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    background: var(--color-surface-muted) !important;
    border-right: 1px solid var(--color-border);
    gap: 2px;
  }

  .timeline-time.is-break {
    background: color-mix(
      in srgb,
      var(--color-surface-muted) 80%,
      var(--color-bg)
    ) !important;
  }

  .slot-label {
    font-size: 9px;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    opacity: 0.7;
  }

  .slot-range {
    font-size: 9px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--color-text-soft);
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    white-space: nowrap;
  }

  .timeline-cell {
    min-height: var(--cell-height);
    padding: 2px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .timeline-time.is-empty,
  .timeline-cell.is-empty {
    min-height: 1.5rem !important;
    max-height: 1.5rem;
  }

  .timeline-cell.is-empty .break-label {
    font-size: 8px;
  }

  .timeline-cell.is-break {
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 5px,
      color-mix(in srgb, var(--color-surface-muted) 30%, transparent) 5px,
      color-mix(in srgb, var(--color-surface-muted) 30%, transparent) 10px
    ) !important;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
  }

  .break-label {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  .timeline-cell:empty {
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      color-mix(in srgb, var(--color-surface-muted) 40%, transparent) 10px,
      color-mix(in srgb, var(--color-surface-muted) 40%, transparent) 20px
    );
  }

  .timeline-empty {
    padding: var(--space-8);
    text-align: center;
  }

  .timeline-empty h3 {
    margin-bottom: var(--space-2);
  }

  @media (max-width: 1100px) {
    .timeline-time span {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }
</style>
