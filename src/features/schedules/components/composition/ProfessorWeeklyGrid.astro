---
import BaseTimeline from "./BaseTimeline.astro";
import ScheduleTile from "@/features/schedules/components/domain/ScheduleTile.astro";
import Legend from "./Legend.astro";
import { getBlockIndex, dayNames } from "@/lib/schedules";

interface Props {
  activeDays: readonly any[];
  scheduleBlocks: readonly any[];
  professorSchedules: Record<string, any>;
  professorNames: string[];
}

const { activeDays, scheduleBlocks, professorSchedules, professorNames } =
  Astro.props;

const getEntries = (name: string) => {
  const professor = professorSchedules[name];
  if (!professor) return [];
  return dayNames.flatMap(({ code }) => professor.by_day[code] ?? []);
};
---

<BaseTimeline title="Grilla Semanal" activeDays={activeDays} scheduleBlocks={scheduleBlocks}>
  <Fragment slot="header-right">
    <p class="text-soft">Solo se muestra el docente seleccionado.</p>
  </Fragment>

  <Fragment slot="tiles">
    {
      professorNames.map((name) =>
        getEntries(name).map((entry) => {
          const startIdx = getBlockIndex(entry.start_block);
          const endIdx = getBlockIndex(entry.end_block);
          const dayIdx = activeDays.findIndex((d) => d.code === entry.day);

          if (dayIdx === -1 || startIdx === -1) return null;

          const rowStart = startIdx + 2;
          const rowSpan = endIdx - startIdx + 1;
          const colStart = dayIdx + 2;

          return (
            <div
              class="timeline-tile-container"
              data-section-id={name}
              style={`grid-row: ${rowStart} / span ${rowSpan}; grid-column: ${colStart}; z-index: 10;`}
              hidden
            >
              <ScheduleTile
                entry={entry}
                sectionId={name}
                label={entry.subject}
              />
            </div>
          );
        })
      )
    }
  </Fragment>

  <Legend />

  <div class="timeline-empty" id="timeline-empty" hidden slot="empty">
    <h3>No hay horarios para mostrar.</h3>
    <p class="text-soft">Selecciona un docente del catálogo lateral.</p>
  </div>
</BaseTimeline>
