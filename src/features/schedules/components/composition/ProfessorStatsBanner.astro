---
import Badge from "@/components/UI/Badge.astro";
import type { SchedulePeriod } from "@/lib/schedules";

interface Props {
  semesterLabel: string;
  totalEntries: number;
  initialProfessor: string;
  initialSessionCount: number;
  schedulePeriods: SchedulePeriod[];
  currentPeriodId: string;
}

const {
  semesterLabel,
  totalEntries,
  initialProfessor,
  initialSessionCount,
  schedulePeriods,
  currentPeriodId,
} = Astro.props;
---

<header class="stats-banner">
  <div class="container stats-container">
    <div class="stats-header">
      <p class="eyebrow">Vista de profesores</p>
      <h2>{semesterLabel}</h2>
    </div>

    <div class="stats-group">
      <div class="stat-item">
        <span>Clases totales</span>
        <Badge variant="muted">{totalEntries}</Badge>
      </div>
      <div class="stat-item">
        <span>Docente activo</span>
        <Badge variant="primary" id="active-professor-badge">
          {initialProfessor}
        </Badge>
      </div>
      <div class="stat-item">
        <span>Sesiones</span>
        <Badge variant="muted" id="active-session-badge">
          {initialSessionCount}
        </Badge>
      </div>
    </div>

    <div class="stats-actions">
      <label class="period-picker-compact">
        <select id="period-select">
          {
            schedulePeriods.map((period) => (
              <option value={period.id} selected={period.id === currentPeriodId}>
                {period.label}
              </option>
            ))
          }
        </select>
      </label>
    </div>
  </div>
</header>

<style>
  .stats-banner {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-2) 0;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  .stats-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .stats-header h2 {
    font-size: var(--font-size-xl);
    margin: 0;
  }

  .stats-group {
    display: flex;
    gap: var(--space-8);
    flex: 1;
    justify-content: center;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .stat-item span {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .period-picker-compact select {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-xs);
    color: var(--color-primary);
  }

  @media (max-width: 1100px) {
    .stats-container {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-4);
    }
    
    .stats-group {
        justify-content: space-between;
        gap: var(--space-2);
    }
  }
</style>
