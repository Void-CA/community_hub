---
import Card from "@/components/UI/Card.astro";

interface DayItem {
  code: string;
  label: string;
}

interface ScheduleSlot {
  type: string;
  label: string;
  range: string;
}

interface Props {
  title: string;
  activeDays: DayItem[];
  scheduleBlocks: readonly ScheduleSlot[];
}

const { title, activeDays, scheduleBlocks } = Astro.props;
---

<Card as="main" class="timeline" padding="lg">
  <div class="timeline-header-actions">
    <div>
      <p class="eyebrow">Visualización</p>
      <h2>{title}</h2>
    </div>
    <div class="timeline-header-right">
      <slot name="header-right" />
      <button id="zen-mode-toggle" class="zen-button">Vista dedicada</button>
    </div>
  </div>

  <div class="timeline-scroll">
    <div
      class="timeline-grid"
      style={`grid-template-columns: 4rem repeat(${activeDays.length}, 1fr);`}
    >
      <!-- 1. Header Corner -->
      <div class="timeline-corner is-sticky"></div>

      <!-- 2. Day Headers -->
      {
        activeDays.map((day) => (
          <div class="timeline-day is-sticky">
            <span>{day.label}</span>
          </div>
        ))
      }

      <!-- 3. Time Axis & Background Cells -->
      {
        scheduleBlocks.map((block, rowIndex) => {
          const isBreak = block.type === "break";
          const rowStart = rowIndex + 2;

          return (
            <Fragment>
              <!-- Time Label -->
              <div
                class:list={["timeline-time", { "is-break": isBreak }]}
                style={`grid-row: ${rowStart}; grid-column: 1;`}
              >
                {isBreak ? (
                  <span class="slot-break-label">{block.label}</span>
                ) : (
                  <Fragment>
                    <span class="slot-range">{block.range}</span>
                    <span class="slot-label">Bloque {block.label}</span>
                  </Fragment>
                )}
              </div>

              <!-- Background Row -->
              {activeDays.map((_, colIndex) => (
                <div
                  class:list={["timeline-bg-cell", { "is-break": isBreak }]}
                  style={`grid-row: ${rowStart}; grid-column: ${colIndex + 2};`}
                >
                  {isBreak && colIndex === 0 && (
                    <span class="break-label-abs">{block.label}</span>
                  )}
                </div>
              ))}
            </Fragment>
          );
        })
      }

      <!-- 4. Tiles (provided by parent) -->
      <slot name="tiles" />
    </div>

    <slot />
  </div>

  <!-- Empty state (provided by parent) -->
  <slot name="empty" />
</Card>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
    transition: all var(--transition-spring);
  }

  .timeline-header-actions {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: var(--space-2);
  }

  .timeline-header-right {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .zen-button {
    background: var(--color-surface-muted);
    border: var(--border-width-sm) solid var(--color-border);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .zen-button:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .zen-button.is-active {
    background: var(--color-primary);
    color: white;
  }

  .timeline-scroll {
    overflow: auto;
    border-radius: var(--radius-lg);
    border: var(--border-width-sm) solid var(--grid-line);
    background: var(--color-bg);
    position: relative;
    max-height: calc(100vh - 220px);
  }

  .timeline-grid {
    display: grid;
    gap: var(--timeline-grid-gap);
    background: var(--grid-line);
    min-width: 100%;
    --cell-height: var(--cell-height);
  }

  .timeline-corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 30;
    background: var(--color-surface-muted);
  }

  .timeline-day {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    background: var(--color-surface-muted);
    border-bottom: var(--border-width-md) solid var(--color-primary);
  }

  .timeline-day span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .timeline-time {
    position: sticky;
    left: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    background: var(--color-surface-muted);
    border-right: var(--border-width-sm) solid var(--color-border);
    gap: 0;
  }

  .timeline-time.is-break {
    background: color-mix(
      in srgb,
      var(--color-surface-muted) 80%,
      var(--color-bg)
    );
  }

  .timeline-time.is-empty,
  .timeline-cell.is-empty {
    min-height: 1.5rem;
    height: 1.5rem;
  }

  .slot-label {
    font-size: var(--font-size-tiny);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    font-family: var(--font-family-mono);
  }

  .slot-range {
    font-size: var(--font-size-2xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    font-family: var(--font-family-mono);
    line-height: 1.2;
  }

  .slot-break-label {
    font-size: var(--font-size-2xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .timeline-bg-cell {
    min-height: var(--cell-height);
    background: var(--color-surface);
    position: relative;
  }

  .timeline-bg-cell.is-break {
    background: repeating-linear-gradient(
      -45deg,
      var(--color-surface-muted),
      var(--color-surface-muted) var(--break-stripe-size),
      color-mix(in srgb, var(--color-surface-muted) 80%, var(--color-bg)) var(--break-stripe-size),
      color-mix(in srgb, var(--color-surface-muted) 80%, var(--color-bg)) calc(var(--break-stripe-size) * 2)
    );
  }

  .timeline-tile-container {
    padding: 3px;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .break-label-abs {
    position: absolute;
    top: 50%;
    left: 50vw;
    transform: translate(-50%, -50%);
    font-size: var(--font-size-2xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    opacity: 0.4;
    white-space: nowrap;
    pointer-events: none;
    z-index: 5;
  }

  .timeline-empty {
    padding: var(--space-8);
    text-align: center;
  }

  .timeline-empty h3 {
    margin-bottom: var(--space-2);
  }

  @media (max-width: 768px) {
    .timeline-time span {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }
</style>
