---
import { ICON_MAP, type IconIntent } from '@/lib/schedules';

interface Props {
  intent: IconIntent;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { intent, size = 20, class: className, strokeWidth = 2.5 } = Astro.props;
const IconComponent = ICON_MAP[intent];
---

{
  IconComponent && (
    <IconComponent size={size} class={className} stroke-width={strokeWidth} />
  )
}
