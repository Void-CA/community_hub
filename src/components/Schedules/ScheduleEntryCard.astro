---
import type { ScheduleEntry } from '../../data/schedulesData';
import { formatBlock, formatDay, getMajorAccent } from '../../data/schedulesData';

interface Props {
  entry: ScheduleEntry;
  compact?: boolean;
}

const { entry, compact = false } = Astro.props;
const primaryMajor = entry.majors[0] ?? 'General';
const accent = getMajorAccent(primaryMajor);
---

<article
  class:list={['schedule-entry', { 'schedule-entry-compact': compact }]}
  data-schedule-entry
  data-day={entry.day.toLowerCase()}
  data-group={String(entry.group)}
  data-majors={entry.majors.map((major) => major.toLowerCase()).join('|')}
  data-professor={entry.professor.toLowerCase()}
  data-subject={entry.subject.toLowerCase()}
  data-room={entry.room.toLowerCase()}
  style={`--schedule-accent: ${accent};`}
>
  <div class="schedule-entry-head">
    <div class="schedule-entry-title-group">
      <p class="schedule-kicker">{formatDay(entry.day)}</p>
      <h3>{entry.subject}</h3>
    </div>

    <span class="schedule-room">{entry.room}</span>
  </div>

  <div class="schedule-meta">
    <div>
      <span>Profesor</span>
      <strong>{entry.professor}</strong>
    </div>

    <div>
      <span>Bloque</span>
      <strong>{formatBlock(entry.start_block)} - {formatBlock(entry.end_block)}</strong>
    </div>

    <div>
      <span>Grupo</span>
      <strong>{entry.group}</strong>
    </div>
  </div>

  <div class="schedule-majors">
    {entry.majors.map((major) => <span>{major}</span>)}
  </div>
</article>

<style>
  .schedule-entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: linear-gradient(180deg, color-mix(in srgb, var(--schedule-accent) 8%, var(--color-surface) 92%), var(--color-surface));
    box-shadow: var(--shadow-sm);
    position: relative;
  }

  .schedule-entry::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: var(--schedule-accent);
  }

  .schedule-entry-compact {
    gap: var(--space-3);
    padding: var(--space-4);
  }

  .schedule-entry-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .schedule-entry-title-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .schedule-kicker {
    margin: 0;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-soft);
  }

  h3 {
    margin: 0;
    font-size: var(--font-size-lg);
  }

  .schedule-room {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-full);
    background: var(--color-surface-muted);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-soft);
    white-space: nowrap;
  }

  .schedule-meta {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .schedule-meta div {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .schedule-meta span {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .schedule-meta strong {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .schedule-majors {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .schedule-majors span {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--schedule-accent) 14%, transparent);
    color: var(--schedule-accent);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
  }

  @media (max-width: 720px) {
    .schedule-meta {
      grid-template-columns: 1fr;
    }
  }
</style>
