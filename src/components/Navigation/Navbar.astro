---
const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Horarios', href: '/campus/schedules' },
  { name: 'Clubes', href: '/campus/clubs' },
];
---

<nav class="navbar">
  <div class="container">
    <a href="/" class="logo">
      <span class="logo-brand">ULSA</span><span class="logo-mark">Hub</span>
    </a>

    <div class="nav-links">
      {
        navItems.map((item) => (
          <a href={item.href} class:list={['nav-link', { 'is-active': Astro.url.pathname === item.href }]}>
            {item.name}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<style>
  .navbar {
    height: var(--navbar-height);
    display: flex;
    align-items: center;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .container {
    display: flex;
    width: 100%;
    align-items: center;
    /* Cambiamos justify-content para asegurar el espacio entre los dos bloques principales */
    justify-content: space-between; 
    margin-left: auto;
    margin-right: auto;
    max-width: var(--container-width);
    padding-left: var(--space-4);
    padding-right: var(--space-4);
    /* Prevenimos que los elementos hijos se encimen en pantallas medianas */
    gap: var(--space-4); 
  }

  .logo {
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    font-family: var(--font-family-heading);
    line-height: 1;
    /* Forzamos que el logo no se colapse bajo ninguna circunstancia */
    flex-shrink: 0; 
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    /* Permitimos que los links se ajusten si es necesario */
    flex-shrink: 1;
    justify-content: flex-end;
  }

  .logo-brand {
    font-size: 1.375rem;
    font-weight: var(--font-weight-black);
    color: var(--color-primary);
    letter-spacing: 0.04em;
  }

  .logo-mark {
    font-size: 1.375rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }


  .nav-link {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-soft);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-surface-muted);
  }

  .nav-link.is-active {
    color: var(--color-text);
    background-color: var(--color-surface-muted);
    font-weight: var(--font-weight-semibold);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
  }
</style>
