---
interface Props {
  title: string;
  description: string;
  href: string;
  category?: string;
  span?: 'small' | 'medium' | 'large';
  color?: string;
}

const { title, description, href, category, span = 'small', color } = Astro.props;

const spanClass = {
  small: 'span-1',
  medium: 'span-2',
  large: 'span-3'
}[span];
---

<a href={href} class={`card bento-card ${spanClass}`} style={color ? `--accent-color: ${color}` : ''}>
  <div class="card-content">
    {category && <span class="category">{category}</span>}
    <div class="header">
      <h3>{title}</h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
    <p>{description}</p>
  </div>
</a>

<style>
  .bento-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 200px;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .category {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--accent-color, var(--color-primary));
    margin-bottom: var(--space-1);
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .icon {
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.2s ease;
    color: var(--color-primary);
  }

  .bento-card:hover .icon {
    opacity: 1;
    transform: translateX(0);
  }

  h3 {
    margin: 0;
    font-size: var(--font-size-xl);
  }

  p {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-soft);
  }

  /* Span options */
  .span-1 { grid-column: span 1; }
  .span-2 { grid-column: span 2; }
  .span-3 { grid-column: span 3; }

  @media (max-width: 1024px) {
    .span-2, .span-3 { grid-column: span 2; }
  }

  @media (max-width: 640px) {
    .span-1, .span-2, .span-3 { grid-column: span 1; }
  }
</style>
