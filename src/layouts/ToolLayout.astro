---
import AppLayout from "./AppLayout.astro";

interface Props {
  title: string;
  description: string;
  previewLabel?: string;
  previewLinkLabel?: string;
  fallbackTitle?: string;
  fallbackDescription?: string;
  fallbackHref?: string;
  fallbackHrefLabel?: string;
}

const {
  title,
  description,
  previewLabel = "Vista previa integrada",
  previewLinkLabel = "Abrir en nueva pestaña",
  fallbackTitle,
  fallbackDescription,
  fallbackHref,
  fallbackHrefLabel,
} = Astro.props;
---

<AppLayout title={title}>
  <div class="tool-page container">
    <header class="tool-header">
      <div class="header-info">
        <h1 class="tool-title">{title}</h1>
        <p class="tool-description">{description}</p>
      </div>
      <div class="header-actions">
        <slot name="actions" />
      </div>
    </header>

    <div class="tool-content">
      <div class="preview-header">
        <span class="preview-label">{previewLabel}</span>
        {
          fallbackHref && (
            <a
              href={fallbackHref}
              target="_blank"
              rel="noreferrer"
              class="preview-link"
            >
              {previewLinkLabel}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </>
              </svg>
            </a>
          )
        }
      </div>

      <div class="preview-container">
        <slot name="preview" />

        <div class="iframe-fallback">
          <h3>{fallbackTitle || "La vista previa no está disponible"}</h3>
          <p>
            {
              fallbackDescription ||
                "Puedes acceder directamente a la herramienta usando el siguiente enlace."
            }
          </p>
          {
            fallbackHref && (
              <a href={fallbackHref} class="btn btn-primary">
                {fallbackHrefLabel || "Abrir herramienta"}
              </a>
            )
          }
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<style>
  .tool-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .tool-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-8);
    gap: var(--space-6);
  }

  .tool-title {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-2);
  }

  .tool-description {
    color: var(--color-text-soft);
    max-width: 600px;
  }

  .header-actions {
    display: flex;
    gap: var(--space-3);
  }

  .preview-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .preview-label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .preview-link {
    font-size: var(--font-size-xs);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .preview-container {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    overflow: hidden;
  }

  /* Fallback stays behind the iframe */
  .iframe-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-8);
    z-index: 0;
  }

  /* The actual content (iframe) goes on top */
  :global(.preview-container > *) {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .tool-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
