---
import AppLayout from "./AppLayout.astro";
import Button from "../components/UI/Button.astro";

interface Props {
  title: string;
  description: string;
  preview?: {
    label?: string;
    linkLabel?: string;
  };
  fallback?: {
    title?: string;
    description?: string;
    href?: string;
    hrefLabel?: string;
  };
}

const {
  title,
  description,
  preview = {},
  fallback = {}
} = Astro.props;

const { 
  label: previewLabel = "Vista previa integrada", 
  linkLabel: previewLinkLabel = "Abrir en nueva pestaña" 
} = preview;

const {
  title: fallbackTitle = "La vista previa no está disponible",
  description: fallbackDescription = "Puedes acceder directamente a la herramienta usando el siguiente enlace.",
  href: fallbackHref,
  hrefLabel: fallbackHrefLabel = "Abrir herramienta"
} = fallback;
---

<AppLayout title={title}>
  <div class="tool-page">
    <header class="tool-hero section">
      <div class="container tool-hero-container">
        <div class="header-info">
          <h1 class="tool-title">{title}</h1>
          <p class="tool-description">{description}</p>
        </div>
        <div class="header-actions">
          <slot name="actions" />
        </div>
      </div>
    </header>

    <div class="container tool-main-content">
      <div class="preview-header">
        <span class="preview-label">{previewLabel}</span>
        {
          fallbackHref && (
            <a
              href={fallbackHref}
              target="_blank"
              rel="noreferrer"
              class="preview-link"
            >
              {previewLinkLabel}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </>
              </svg>
            </a>
          )
        }
      </div>

      <div class="preview-wrapper">
        <div class="preview-container">
          <slot name="preview" />
          
          <div class="iframe-fallback">
            <h3>{fallbackTitle}</h3>
            <p>{fallbackDescription}</p>
            {
              fallbackHref && (
                <Button href={fallbackHref} variant="primary">
                  {fallbackHrefLabel}
                </Button>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<style>
  .tool-page {
    padding-bottom: var(--space-12);
  }

  .tool-hero {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }

  .tool-hero-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-8);
  }

  .tool-title {
    font-size: clamp(2rem, 5vw, var(--font-size-4xl));
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .tool-description {
    color: var(--color-text-soft);
    font-size: var(--font-size-lg);
    max-width: 640px;
    line-height: 1.6;
  }

  .header-actions {
    display: flex;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .tool-main-content {
    margin-top: var(--space-4);
  }

  .preview-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
    padding: 0 var(--space-1);
  }

  .preview-label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .preview-link {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: var(--space-1);
    transition: opacity 0.2s ease;
  }

  .preview-link:hover {
    opacity: 0.8;
  }

  .preview-wrapper {
    position: relative;
    padding: var(--space-2);
    background-color: var(--color-surface-muted);
    border-radius: calc(var(--radius-lg) + var(--space-2));
    border: 1px solid var(--color-border-soft);
  }

  .preview-container {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--neutral-0);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  /* Centralized Iframe Styling */
  :global(.preview-container iframe) {
    width: 100%;
    min-height: 1000px;
    height: 90vh;
    border: none;
    background: white;
    display: block;
  }

  .iframe-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-12);
    z-index: 0;
    background-color: var(--color-bg);
  }

  :global(.preview-container > *) {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1024px) {
    .tool-hero-container {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }
    
    .header-actions {
      width: 100%;
    }

    :global(.preview-container iframe) {
      min-height: 700px;
    }
  }
</style>
