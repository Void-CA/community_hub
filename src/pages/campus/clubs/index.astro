---
import AppLayout from '@/layouts/AppLayout.astro';
import { getAllClubs } from '@/lib/clubs';
import { Code, Zap, Target } from 'lucide-astro';

const clubs = getAllClubs();

const clubIcons: Record<string, typeof Code> = {
  programming: Code,
  electronics: Zap,
};

const clubAccents: Record<string, { lightBg: string; lightText: string; lightBorder: string; darkBg: string; darkText: string; darkBorder: string }> = {
  programming: {
    lightBg: 'linear-gradient(135deg, var(--brand-50) 0%, var(--brand-100) 100%)',
    lightText: 'var(--brand-600)',
    lightBorder: 'var(--brand-100)',
    darkBg: 'linear-gradient(135deg, var(--brand-950) 0%, var(--neutral-900) 100%)',
    darkText: 'var(--brand-400, #818cf8)',
    darkBorder: 'color-mix(in srgb, var(--brand-500) 25%, transparent)',
  },
  electronics: {
    lightBg: 'linear-gradient(135deg, var(--accent-50) 0%, color-mix(in srgb, var(--accent-500) 10%, var(--neutral-50)) 100%)',
    lightText: 'var(--accent-600)',
    lightBorder: 'color-mix(in srgb, var(--accent-500) 20%, transparent)',
    darkBg: 'linear-gradient(135deg, var(--accent-950) 0%, var(--neutral-900) 100%)',
    darkText: 'var(--accent-400, #fb923c)',
    darkBorder: 'color-mix(in srgb, var(--accent-500) 25%, transparent)',
  },
};

interface AccentColors {
  lightBg: string;
  lightText: string;
  lightBorder: string;
  darkBg: string;
  darkText: string;
  darkBorder: string;
}
---

<AppLayout
  title="Clubes Universitarios"
  description="Descubre los clubes estudiantiles de la ULSA: propósito, impacto y horarios de encuentros."
>
  <section class="clubs-page">
    <div class="container">
      <header class="clubs-hero">
        <p class="clubs-eyebrow">Vida Estudiantil</p>
        <h1>Clubes Universitarios</h1>
        <p class="clubs-intro">
          Iniciativas creadas por y para estudiantes. Descubrí su propósito, su impacto y cuándo se reúnen.
        </p>
      </header>

      <div class="clubs-grid">
        {
          clubs.map(({ profile }) => {
            const accent: AccentColors = clubAccents[profile.slug] ?? {
              lightBg: 'var(--color-surface-muted)',
              lightText: 'var(--color-primary)',
              lightBorder: 'var(--color-border)',
              darkBg: 'var(--color-surface)',
              darkText: 'var(--color-primary)',
              darkBorder: 'var(--color-border)',
            };
            const Icon = clubIcons[profile.slug] ?? Target;
            return (
              <a href={`/campus/clubs/${profile.slug}`} class:list={['club-card', `is-${profile.slug}`]} style={`--club-bg-light: ${accent.lightBg}; --club-text-light: ${accent.lightText}; --club-border-light: ${accent.lightBorder}; --club-bg-dark: ${accent.darkBg}; --club-text-dark: ${accent.darkText}; --club-border-dark: ${accent.darkBorder};`}>
                <div class="club-card-icon">
                  <Icon size={32} strokeWidth={1.5} />
                </div>
                <h3 class="club-card-name">{profile.name}</h3>
                <p class="club-card-tagline">{profile.tagline}</p>
                <div class="club-card-footer">
                  <span class="club-card-leaders">
                    {profile.leaders.join(' · ')}
                  </span>
                  <span class="club-card-cta">Ver más →</span>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>
</AppLayout>

<style>
  .clubs-page {
    padding: var(--space-12) 0 var(--space-16);
  }

  .clubs-hero {
    margin-bottom: var(--space-12);
    text-align: center;
  }

  .clubs-eyebrow {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .clubs-hero h1 {
    margin: 0 0 var(--space-4);
    font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
    font-weight: var(--font-weight-black);
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .clubs-intro {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .clubs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-6);
    max-width: 800px;
    margin: 0 auto;
  }

  .club-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--club-border-light);
    background: var(--club-bg-light);
    transition: all var(--transition-slow);
    position: relative;
    overflow: hidden;
  }

  .club-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--club-text-light);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-slow);
  }

  .club-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--club-text-light);
  }

  .club-card:hover::before {
    transform: scaleX(1);
  }

  .club-card-icon {
    margin-bottom: var(--space-4);
    color: var(--club-text-light);
    display: flex;
    align-items: center;
  }

  .club-card-name {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    line-height: 1.2;
  }

  .club-card-tagline {
    margin: 0 0 var(--space-6);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
    flex: 1;
  }

  .club-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-4);
    border-top: 1px solid var(--club-border-light);
  }

  .club-card-leaders {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--club-text-light);
  }

  .club-card-cta {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--club-text-light);
    transition: transform var(--transition-base);
  }

  .club-card:hover .club-card-cta {
    transform: translateX(4px);
  }

  /* Dark Mode */
  @media (prefers-color-scheme: dark) {
    .club-card {
      border-color: var(--club-border-dark);
      background: var(--club-bg-dark);
    }

    .club-card::before {
      background: var(--club-text-dark);
    }

    .club-card:hover {
      border-color: var(--club-text-dark);
    }

    .club-card-icon {
      color: var(--club-text-dark);
    }

    .club-card-leaders,
    .club-card-cta {
      color: var(--club-text-dark);
    }
  }
</style>
