---
import AppLayout from '@/layouts/AppLayout.astro';
import { getAllClubSlugs, getClub } from '@/lib/clubs';
import {
  Code,
  Zap,
  Target,
  Calendar,
  ArrowLeft,
  Clock,
  MapPin,
  Users,
  ExternalLink,
} from 'lucide-astro';

export function getStaticPaths() {
  const slugs = getAllClubSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const { profile, meetings } = getClub(slug!);

const clubIcons: Record<string, typeof Code> = {
  programming: Code,
  electronics: Zap,
};

const Icon = clubIcons[slug!] ?? Target;
---

<AppLayout
  title={`${profile.name} | Clubes Universitarios`}
  description={profile.tagline}
>
  <section class="club-detail">
    <div class="container">
      <a href="/campus/clubs" class="back-link">
        <ArrowLeft size={16} strokeWidth={2} />
        Clubes
      </a>

      <!-- Hero -->
      <header class="club-hero">
        <div class="club-hero-icon">
          <Icon size={36} strokeWidth={1.5} />
        </div>
        <h1>{profile.name}</h1>
        <p class="club-hero-tagline">{profile.tagline}</p>
        <span class="club-category-badge">Dominio: {profile.tags[0]?.label ?? 'General'}</span>
      </header>

      <!-- Main Grid: 70/30 -->
      <div class="club-body">
        <!-- Columna Principal (70%) — Showcase -->
        <div class="club-main">
          <!-- Nuestra Esencia -->
          <section class="essence-section">
            <h2>Nuestra Esencia</h2>
            <p class="essence-text">{profile.manifesto}</p>
          </section>

          <!-- Galería de Salida -->
          {
            profile.gallery.length > 0 && (
              <section class="gallery-section">
                <h2>Galería de Salida</h2>
                <div class="gallery-grid">
                  {
                    profile.gallery.map((item) => (
                      <article class="gallery-item">
                        <div class="gallery-item-image">
                          {item.image ? (
                            <img src={item.image} alt={item.title} loading="lazy" />
                          ) : (
                            <div class="gallery-placeholder" />
                          )}
                        </div>
                        <div class="gallery-item-body">
                          <h3>{item.title}</h3>
                          <p>{item.description}</p>
                        </div>
                      </article>
                    ))
                  }
                </div>
              </section>
            )
          }

          <!-- Mapa de Habilidades -->
          <section class="skills-section">
            <h2>Líneas de Interés</h2>
            <div class="tags-list">
              {
                profile.tags.map((tag) => (
                  <span class="tag-pill">{tag.label}</span>
                ))
              }
            </div>
          </section>

          <!-- Encuentros -->
          {
            meetings.length > 0 && (
              <section class="meetings-section">
                <h2>
                  <Calendar size={20} strokeWidth={1.5} />
                  Encuentros
                </h2>
                <div class="meetings-list">
                  {
                    meetings.map((meeting) => (
                      <article class="meeting-card">
                        <div class="meeting-header">
                          <span class="meeting-day">{meeting.day === 'L' ? 'Lunes' : meeting.day === 'M' ? 'Martes' : meeting.day === 'X' ? 'Miércoles' : meeting.day === 'J' ? 'Jueves' : meeting.day === 'V' ? 'Viernes' : meeting.day}</span>
                          <span class="meeting-time">{meeting.startTime} — {meeting.endTime}</span>
                        </div>
                        <p class="meeting-location">{meeting.location}</p>
                        <p class="meeting-desc">{meeting.description}</p>
                      </article>
                    ))
                  }
                </div>
              </section>
            )
          }
        </div>

        <!-- Columna Lateral (30%) — Contrato -->
        <aside class="club-sidebar">
          <!-- Card de Participación -->
          <div class="participation-card">
            <h3>Contrato de Participación</h3>

            <div class="participation-row">
              <Clock size={18} strokeWidth={1.5} class="participation-icon" />
              <div>
                <span class="participation-label">Intensidad</span>
                <p>{profile.participation.commitment}</p>
              </div>
            </div>

            <div class="participation-row">
              <Users size={18} strokeWidth={1.5} class="participation-icon" />
              <div>
                <span class="participation-label">Perfil</span>
                <p>{profile.participation.memberProfile}</p>
              </div>
            </div>

            <div class="participation-row">
              <MapPin size={18} strokeWidth={1.5} class="participation-icon" />
              <div>
                <span class="participation-label">Ubicación</span>
                <p>{profile.references.location}</p>
              </div>
            </div>

            <div class="participation-row">
              <span class="participation-icon requisites-icon">?</span>
              <div>
                <span class="participation-label">Requisitos</span>
                <p>{profile.participation.requirements}</p>
              </div>
            </div>
          </div>

          <!-- Directorio de Referentes -->
          <div class="references-card">
            <h3>Miembros de la directiva</h3>
            <ul class="contacts-list">
              {
                profile.references.contacts.map((contact) => (
                  <li class="contact-item">
                    <div class="contact-avatar">{contact.name.charAt(0)}</div>
                    <div class="contact-info">
                      <span class="contact-name">{contact.name}</span>
                      {contact.role && <span class="contact-role">{contact.role}</span>}
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Acción Directa -->
          {
            Object.keys(profile.social).length > 0 && (
              <div class="social-card">
                <h3>Contactar</h3>
                <div class="social-links">
                  {
                    Object.entries(profile.social).map(([platform, url]) => (
                      <a
                        href={url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="social-link"
                      >
                        {platform.charAt(0).toUpperCase() + platform.slice(1)}
                        <ExternalLink size={14} strokeWidth={2} />
                      </a>
                    ))
                  }
                </div>
              </div>
            )
          }
        </aside>
      </div>
    </div>
  </section>
</AppLayout>

<style>
  .club-detail {
    padding: var(--space-8) 0 var(--space-16);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .back-link:hover {
    color: var(--color-text);
    background-color: var(--color-surface-muted);
  }

  /* ── Hero ── */
  .club-hero {
    margin-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
  }

  .club-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-primary);
  }

  .club-hero-icon {
    color: var(--color-primary);
    display: flex;
    align-items: center;
  }

  .club-hero h1 {
    margin: 0;
    font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .club-hero-tagline {
    margin: 0;
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-width: 500px;
    line-height: 1.5;
  }

  .club-category-badge {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  /* ── Body Layout: 70/30 ── */
  .club-body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-10);
    align-items: start;
  }

  .club-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .club-main h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* ── Essence ── */
  .essence-text {
    margin: 0;
    font-size: var(--font-size-base);
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ── Gallery ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
  }

  .gallery-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .gallery-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .gallery-item-image {
    aspect-ratio: 1 / 1;
    background: var(--color-surface-muted);
    overflow: hidden;
  }

  .gallery-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface-muted) 0%, var(--color-surface) 100%);
  }

  .gallery-item-body {
    padding: var(--space-3);
  }

  .gallery-item-body h3 {
    margin: 0 0 var(--space-1);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
  }

  .gallery-item-body p {
    margin: 0;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Tags ── */
  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag-pill {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-soft);
    background: var(--color-surface-muted);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-soft);
  }

  /* ── Meetings ── */
  .meetings-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .meeting-card {
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    transition: all var(--transition-base);
  }

  .meeting-card:hover {
    box-shadow: var(--shadow-sm);
    border-color: var(--color-primary);
  }

  .meeting-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .meeting-day {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meeting-time {
    font-size: var(--font-size-xs);
    font-family: var(--font-family-mono);
    color: var(--color-text-muted);
    background: var(--color-surface-muted);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .meeting-location {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
  }

  .meeting-desc {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Sidebar ── */
  .club-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    position: sticky;
    top: calc(var(--navbar-height) + var(--space-4));
  }

  .club-sidebar h3 {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  /* Participation Card */
  .participation-card {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  .participation-row {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .participation-row:last-child {
    border-bottom: none;
  }

  .participation-icon {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 2px;
  }

  .requisites-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    font-size: 13px;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    margin-top: 2px;
  }

  .participation-label {
    display: block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .participation-row p {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  /* References Card */
  .references-card {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  .contacts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .contact-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    flex-shrink: 0;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .contact-name {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
  }

  .contact-role {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  /* Social Card */
  .social-card {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-primary);
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .social-link:hover {
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .club-body {
      grid-template-columns: 1fr;
    }

    .club-sidebar {
      position: static;
      order: -1;
    }

    .gallery-grid {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }
  }
</style>
