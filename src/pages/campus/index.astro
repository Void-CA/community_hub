---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Campus">
  <section class="section">
    <div class="container text-center">
      <h1>Campus</h1>
      <p class="text-soft">Información relevante sobre el entorno universitario y eventos.</p>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="grid grid-cols-2">
        <div class="card">
          <h3>Calendario Escolar</h3>
          <p>Fechas de inicio, exámenes y días feriados.</p>
        </div>
        <div class="card">
          <h3>Eventos Próximos</h3>
          <p>Actividades culturales y deportivas.</p>
        </div>
      </div>
    </div>
  </section>
</AppLayout>
