---
import GlobalSearch from "@/features/schedules/components/composition/GlobalSearch.astro";
import Card from "@/components/UI/Card.astro";
import Badge from "@/components/UI/Badge.astro";
import DynamicIcon from "@/components/UI/DynamicIcon.astro";
import {
  semesterLabel,
  groups,
  scheduleEntries,
  getScheduleSummary,
} from "@/lib/schedules";
import AppLayout from "@/layouts/AppLayout.astro";

const summary = getScheduleSummary(scheduleEntries);

const spotlightItems = [
  {
    title: "Vista de Estudiantes",
    description:
      "Consulta por carrera, año y grupo con detección de conflictos.",
    href: "/campus/schedules/students",
    intent: "student",
  },
  {
    title: "Vista de Profesores",
    description: "Busca a un docente y revisa su carga semanal y materias.",
    href: "/campus/schedules/professors",
    intent: "professor",
  },
];
---

<AppLayout
  title={`Horarios Académicos | ${semesterLabel}`}
  description="Sistema de consulta de horarios académicos procesados por el Community Hub."
>
  <section class="section schedule-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Sistema de Horarios Académicos</p>
        <h1 class="hero-title">
          Tus horarios, <span class="text-gradient">claros y consultables</span
          >.
        </h1>
        <p class="hero-text text-soft">
          Explora la carga académica del periodo <strong>{semesterLabel}</strong
          >. Datos sincronizados desde el catálogo oficial de la universidad.
        </p>

        <GlobalSearch />

        <div class="hero-meta">
          <Badge size="xs" variant="muted">Dataset v2.4</Badge>
          <span class="text-xs text-soft"
            >Última actualización: Hoy, 08:30 AM</span
          >
        </div>
      </div>

      <Card class="hero-panel" padding="lg">
        <div class="panel-top">
          <span class="panel-tag">Datos del periodo</span>
          <Badge variant="primary">{semesterLabel}</Badge>
        </div>

        <div class="panel-grid">
          <a href="/campus/schedules/students" class="panel-stat">
            <div class="stat-head">
              <DynamicIcon intent="professor" size={14} class="text-primary" />
              <span>Profesores</span>
            </div>
            <strong>{summary.totalProfessors}</strong>
          </a>
          <a href="/campus/schedules/students" class="panel-stat">
            <div class="stat-head">
              <DynamicIcon intent="student" size={14} class="text-primary" />
              <span>Carreras</span>
            </div>
            <strong>{summary.totalMajors}</strong>
          </a>
          <a href="/campus/schedules/students" class="panel-stat">
            <div class="stat-head">
              <DynamicIcon intent="room" size={14} class="text-primary" />
              <span>Grupos</span>
            </div>
            <strong>{groups.length}</strong>
          </a>
          <a href="/campus/schedules/students" class="panel-stat">
            <div class="stat-head">
              <DynamicIcon intent="time" size={14} class="text-primary" />
              <span>Clases</span>
            </div>
            <strong>{summary.totalEntries}</strong>
          </a>
        </div>

        <div class="panel-insight">
          <div class="insight-label">
            <DynamicIcon intent="info" size={12} />
            Insight del periodo
          </div>
          <p class="insight-value">
            La materia con más secciones es <strong
              >{summary.mostPopularSubject?.name}</strong
            >
            con {summary.mostPopularSubject?.count} grupos activos.
          </p>
        </div>
      </Card>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Accesos principales</p>
          <h2>Explora por tipo de consulta</h2>
        </div>
      </div>

      <div class="grid access-grid">
        {
          spotlightItems.map((item) => (
            <a class="card access-card" href={item.href}>
              <div class="access-icon">
                <DynamicIcon intent={item.intent as any} size={32} />
              </div>
              <div class="access-content">
                <h3>{item.title}</h3>
                <p class="text-soft">{item.description}</p>
              </div>
              <div class="access-arrow">
                <DynamicIcon intent="arrow" />
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="transparency card">
        <div>
          <p class="eyebrow">Transparencia</p>
          <h2>Datos oficiales, presentados por el hub</h2>
        </div>

        <p class="text-soft">
          Los horarios se procesan a partir de PDFs oficiales de la universidad
          para mejorar su lectura y navegación. El hub organiza la información,
          pero no reemplaza el sistema académico institucional.
        </p>
      </div>
    </div>
  </section>
</AppLayout>

<style>
  .schedule-hero {
    padding-bottom: var(--space-8);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  .hero-title {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    max-width: 12ch;
  }

  .hero-text {
    max-width: 60ch;
    font-size: var(--font-size-lg);
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }

  .hero-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    background: linear-gradient(
      180deg,
      var(--color-surface) 0%,
      color-mix(in srgb, var(--color-surface) 95%, var(--color-primary)) 100%
    );
  }

  .panel-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .panel-tag {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .panel-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .panel-stat {
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .panel-stat:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    background: var(--color-surface);
  }

  .stat-head {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .panel-stat span {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .panel-stat strong {
    font-size: var(--font-size-2xl);
    color: var(--color-primary);
  }

  .panel-insight {
    margin-top: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background: color-mix(
      in srgb,
      var(--color-accent) 5%,
      var(--color-surface)
    );
    border: 1px dashed var(--color-accent);
  }

  .insight-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 6px;
  }

  .insight-value {
    font-size: var(--font-size-sm);
    margin: 0;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: var(--space-6);
    align-items: end;
    margin-bottom: var(--space-5);
  }

  .access-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .access-card {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5);
    text-decoration: none;
    color: inherit;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .access-card:hover {
    border-color: var(--color-primary);
    background: color-mix(
      in srgb,
      var(--color-primary) 2%,
      var(--color-surface)
    );
    transform: scale(1.01);
  }

  .access-icon {
    font-size: 2.5rem;
    background: var(--color-surface-muted);
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-xl);
  }

  .access-content {
    flex: 1;
  }

  .access-content h3 {
    margin: 0 0 4px 0;
  }

  .access-arrow {
    font-size: 1.5rem;
    color: var(--color-primary);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }

  .access-card:hover .access-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .transparency {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: var(--space-6);
    align-items: center;
  }

  @media (max-width: 960px) {
    .hero-grid,
    .transparency {
      grid-template-columns: 1fr;
    }

    .section-heading {
      grid-template-columns: 1fr;
      display: grid;
    }

    .semester-grid,
    .access-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
