---
import AppLayout from '@/layouts/AppLayout.astro';
import {
  dayNames,
  resolveScheduleDatasetByYearTerm,
  scheduleBlocks,
  schedulePeriods,
} from '@/lib/schedules';
import { ProfessorDashboard } from '@/features/schedules/react/professor/ProfessorDashboard';

const yearParam = Astro.url.searchParams.get('year');
const termParam = Astro.url.searchParams.get('term');
const dataset = resolveScheduleDatasetByYearTerm(yearParam, termParam);
const semesterLabel = dataset.period.label;
const scheduleEntries = dataset.entries;
const professorSchedules = dataset.professorSchedules;

const professorNames = Object.keys(professorSchedules).sort((a, b) =>
  new Intl.Collator('es', { sensitivity: 'base' }).compare(a, b),
);
const initialProfessor = professorNames[0] ?? '';
const activeDays = dayNames.filter((day) =>
  scheduleEntries.some((entry) => entry.day === day.code),
);
---

<AppLayout
  title={`Horarios de Profesores | ${semesterLabel}`}
  description="Vista compacta de horarios para profesores, con búsqueda por nombre y grilla por bloques."
>
  <ProfessorDashboard
    client:load
    professorNames={professorNames}
    professorSchedules={professorSchedules}
    initialProfessor={initialProfessor}
    activeDays={activeDays}
    scheduleBlocks={scheduleBlocks}
    schedulePeriods={schedulePeriods}
    activePeriodId={dataset.period.id}
  />
</AppLayout>
