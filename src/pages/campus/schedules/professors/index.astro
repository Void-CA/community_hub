---
import AppLayout from "@/layouts/AppLayout.astro";
import ScheduleTile from "@/features/schedules/components/domain/ScheduleTile.astro";
import Card from "@/components/UI/Card.astro";
import Badge from "@/components/UI/Badge.astro";
import {
  dayNames,
  getScheduleSummary,
  resolveScheduleDatasetByYearTerm,
  scheduleBlocks,
  schedulePeriods,
  getBlockIndex,
} from "@/lib/schedules";

const yearParam = Astro.url.searchParams.get("year");
const termParam = Astro.url.searchParams.get("term");
const dataset = resolveScheduleDatasetByYearTerm(yearParam, termParam);
const semesterLabel = dataset.period.label;
const scheduleEntries = dataset.entries;
const professorSchedules = dataset.professorSchedules;
const professorNames = Object.keys(professorSchedules).sort(
  new Intl.Collator("es", { sensitivity: "base" }).compare,
);

const getProfessorEntries = (professorName: string) => {
  const professor = professorSchedules[professorName];

  if (!professor) {
    return [];
  }

  return dayNames.flatMap(({ code }) => professor.by_day[code] ?? []);
};

const getProfessorTilesForCell = (dayCode: string, blockLabel: string) => {
  const current = getBlockIndex(blockLabel);

  return professorNames.flatMap((name) =>
    getProfessorEntries(name)
      .filter((entry) => {
        if (entry.day !== dayCode) return false;
        const start = getBlockIndex(entry.start_block);
        return current === start;
      })
      .map((entry) => {
        const start = getBlockIndex(entry.start_block);
        const end = getBlockIndex(entry.end_block);
        return { entry, professorName: name, rowSpan: end - start + 1 };
      }),
  );
};

const isBlockOccupied = (blockLabel: string) => {
  const current = getBlockIndex(blockLabel);
  return professorNames.some((name) =>
    getProfessorEntries(name).some((entry) => {
      const start = getBlockIndex(entry.start_block);
      const end = getBlockIndex(entry.end_block);
      return current >= start && current <= end;
    }),
  );
};

const activeDays = dayNames.filter((day) =>
  scheduleEntries.some((entry) => entry.day === day.code),
);
const initialProfessor = professorNames[0] ?? "";
const initialEntries = getProfessorEntries(initialProfessor);
const summary = getScheduleSummary(scheduleEntries);
const activeSummary = getScheduleSummary(initialEntries);
---

<AppLayout
  title={`Horarios de Profesores | ${semesterLabel}`}
  description="Vista compacta de horarios para profesores, con búsqueda por nombre y grilla por bloques."
>
  <header class="stats-banner">
    <div class="container stats-container">
      <div class="stats-header">
        <p class="eyebrow">Vista de profesores</p>
        <h2>{semesterLabel}</h2>
      </div>

      <div class="stats-group">
        <div class="stat-item">
          <span>Clases totales</span>
          <Badge variant="muted">{summary.totalEntries}</Badge>
        </div>
        <div class="stat-item">
          <span>Docente activo</span>
          <Badge variant="primary" id="active-professor-badge"
            >{initialProfessor}</Badge
          >
        </div>
        <div class="stat-item">
          <span>Sesiones</span>
          <Badge variant="muted" id="active-session-badge"
            >{activeSummary.totalEntries}</Badge
          >
        </div>
      </div>

      <div class="stats-actions">
        <label class="period-picker-compact">
          <select id="period-select">
            {
              schedulePeriods.map((period) => (
                <option
                  value={period.id}
                  selected={period.id === dataset.period.id}
                >
                  {period.label}
                </option>
              ))
            }
          </select>
        </label>
      </div>
    </div>
  </header>

  <section class="section pt-0">
    <div class="container dashboard-grid">
      <Card as="aside" class="catalog" padding="lg">
        <div class="catalog-head">
          <div>
            <p class="eyebrow">Catálogo</p>
            <h2>Docentes</h2>
          </div>
          <p class="catalog-count text-soft">
            <span id="visible-professor-count">{professorNames.length}</span> disponibles
          </p>
        </div>

        <label class="search-box">
          <span class="sr-only">Buscar profesor</span>
          <input
            id="professor-search"
            type="search"
            placeholder="Buscar por nombre"
          />
        </label>

        <div class="catalog-list" data-professor-list>
          {
            professorNames.map((name) => {
              const entries = getProfessorEntries(name);
              const days = new Set(entries.map((entry) => entry.day)).size;
              const subjects = new Set(entries.map((entry) => entry.subject))
                .size;

              return (
                <button
                  type="button"
                  class:list={[
                    "section-card",
                    { "is-selected": name === initialProfessor },
                  ]}
                  data-professor-button
                  data-professor={name}
                  data-search={name.toLowerCase()}
                  aria-pressed={name === initialProfessor}
                >
                  <div class="section-card-top">
                    <div>
                      <h3>{name}</h3>
                      <p class="section-subtitle">
                        {subjects} materias en {days} días
                      </p>
                    </div>
                    <div class="workload-indicator">
                      {["L", "M", "X", "J", "V"].map((code) => {
                        const count = entries.filter(
                          (e) => e.day === code,
                        ).length;
                        return (
                          <span
                            class:list={[
                              "workload-dot",
                              { "has-load": count > 0, "high-load": count > 3 },
                            ]}
                            title={`${count} sesiones`}
                          />
                        );
                      })}
                    </div>
                  </div>
                </button>
              );
            })
          }
        </div>
      </Card>

      <Card as="main" class="timeline" padding="lg">
        <div class="timeline-head">
          <div>
            <p class="eyebrow">Visualización</p>
            <h2>Grilla Semanal</h2>
          </div>
          <div class="timeline-actions">
            <p class="text-soft">Solo se muestra el docente seleccionado.</p>
            <button id="zen-mode-toggle" class="zen-button"
              >Vista dedicada</button
            >
          </div>
        </div>

        <div class="timeline-scroll">
          <div
            class="timeline-grid"
            style={`grid-template-columns: 5rem repeat(${activeDays.length}, minmax(12rem, 1fr));`}
          >
            <div class="timeline-corner"></div>
            {
              activeDays.map((day) => (
                <div class="timeline-day">
                  <span>{day.label}</span>
                </div>
              ))
            }

            {
              scheduleBlocks.map((block) => {
                const isBreak = block.type === "break";
                const occupied = isBlockOccupied(block.label);

                return (
                  <Fragment>
                    <div
                      class:list={[
                        "timeline-time",
                        {
                          "is-break": isBreak,
                          "is-empty": isBreak && !occupied,
                        },
                      ]}
                    >
                      <span class="slot-label">{block.label || ""}</span>
                      <span class="slot-range">{block.range}</span>
                    </div>
                    {activeDays.map((day) => {
                      const tilesForCell = getProfessorTilesForCell(
                        day.code,
                        block.label,
                      );

                      return (
                        <div
                          class:list={[
                            "timeline-cell",
                            {
                              "is-break": isBreak,
                              "is-empty": isBreak && !occupied,
                            },
                          ]}
                        >
                          {isBreak && !occupied ? (
                            <span class="break-label">{block.label}</span>
                          ) : (
                            tilesForCell.map(
                              ({ entry, professorName, rowSpan }) => (
                                <ScheduleTile
                                  entry={entry}
                                  sectionId={professorName}
                                  label={entry.subject}
                                  style={
                                    rowSpan && rowSpan > 1
                                      ? `grid-row: span ${rowSpan}; height: calc(${rowSpan} * (var(--cell-height) + 1px) - 1px);`
                                      : ""
                                  }
                                />
                              ),
                            )
                          )}
                        </div>
                      );
                    })}
                  </Fragment>
                );
              })
            }
          </div>
        </div>

        <div class="timeline-empty" id="timeline-empty" hidden>
          <h3>No hay horarios para mostrar.</h3>
          <p class="text-soft">Selecciona un docente del catálogo lateral.</p>
        </div>
      </Card>
    </div>
  </section>

  <script is:inline>
    const initialProfessor =
      document.querySelector("[data-initial-professor]")?.dataset
        .initialProfessor ?? "";
    const professorButtons = [
      ...document.querySelectorAll("[data-professor-button]"),
    ];
    const tiles = [...document.querySelectorAll("[data-schedule-tile]")];
    const searchInput = document.getElementById("professor-search");
    const visibleProfessorCount = document.getElementById(
      "visible-professor-count",
    );
    const activeProfessorBadge = document.getElementById(
      "active-professor-badge",
    );
    const activeSessionBadge = document.getElementById("active-session-badge");
    const timelineEmpty = document.getElementById("timeline-empty");
    const periodSelect = document.getElementById("period-select");

    // Zen Mode
    const zenToggle = document.getElementById("zen-mode-toggle");
    const dashboard = document.querySelector(".dashboard-grid");

    const state = {
      professor: initialProfessor,
    };

    const updateSummary = () => {
      const selectedTiles = tiles.filter(
        (tile) => tile.dataset.sectionId === state.professor,
      );

      if (activeProfessorBadge) {
        activeProfessorBadge.textContent = state.professor || "Sin selección";
      }

      if (activeSessionBadge) {
        activeSessionBadge.textContent = String(selectedTiles.length);
      }

      if (timelineEmpty) {
        timelineEmpty.hidden = Boolean(state.professor);
      }
    };

    const applyState = () => {
      const query = searchInput?.value.trim().toLowerCase() ?? "";
      const visibleButtons = [];

      professorButtons.forEach((button) => {
        const name = button.dataset.professor ?? "";
        const matches =
          query.length === 0 || name.toLowerCase().includes(query);

        button.hidden = !matches;

        if (matches) {
          visibleButtons.push(button);
        }
      });

      const hasCurrentVisible = visibleButtons.some(
        (button) => (button.dataset.professor ?? "") === state.professor,
      );

      if (!hasCurrentVisible && visibleButtons.length > 0) {
        state.professor = visibleButtons[0]?.dataset.professor ?? "";
      }

      professorButtons.forEach((button) => {
        const selected = (button.dataset.professor ?? "") === state.professor;
        button.classList.toggle("is-selected", selected);
        button.setAttribute("aria-pressed", String(selected));
      });

      tiles.forEach((tile) => {
        tile.hidden = tile.dataset.sectionId !== state.professor;
      });

      visibleProfessorCount.textContent = String(
        professorButtons.filter((button) => !button.hidden).length,
      );
      updateSummary();
    };

    const selectProfessor = (name) => {
      state.professor = name;
      applyState();
    };

    professorButtons.forEach((button) => {
      button.addEventListener("click", () =>
        selectProfessor(button.dataset.professor ?? initialProfessor),
      );
    });

    searchInput?.addEventListener("input", applyState);

    zenToggle?.addEventListener("click", () => {
      dashboard?.classList.toggle("is-zen");
      zenToggle.classList.toggle("is-active");
      const isZen = dashboard?.classList.contains("is-zen");
      zenToggle.textContent = isZen ? "Ver catálogo" : "Vista dedicada";
    });

    periodSelect?.addEventListener("change", () => {
      const selected = periodSelect.value;
      const [year, term] = selected.split("-");
      const nextUrl = new URL(window.location.href);
      nextUrl.searchParams.set("year", year ?? "");
      nextUrl.searchParams.set("term", term ?? "");
      window.location.assign(nextUrl.toString());
    });

    selectProfessor(initialProfessor);
  </script>
</AppLayout>

<style>
  .schedule-hero {
    padding-bottom: var(--space-8);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  .hero-panel,
  .catalog,
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .panel-top,
  .catalog-head,
  .timeline-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: flex-end;
  }

  .timeline-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .zen-button {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .zen-button:hover,
  .zen-button.is-active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .panel-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .panel-grid div {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
  }

  .panel-grid span {
    display: block;
    margin-bottom: var(--space-1);
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .panel-grid strong {
    font-size: var(--font-size-2xl);
  }

  /* Stats Banner */
  .stats-banner {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  .stats-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .stats-header h2 {
    font-size: var(--font-size-xl);
    margin: 0;
  }

  .stats-group {
    display: flex;
    gap: var(--space-8);
    flex: 1;
    justify-content: center;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .stat-item span {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .period-picker-compact select {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-xs);
    color: var(--color-primary);
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 22rem 1fr;
    gap: var(--space-6);
    align-items: start;
    max-width: 100% !important;
    padding: 0 var(--space-6);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Zen Mode */
  .dashboard-grid.is-zen {
    grid-template-columns: 0px 1fr;
    gap: 0;
  }

  .dashboard-grid.is-zen .catalog {
    transform: translateX(-100%);
    opacity: 0;
    pointer-events: none;
    margin-right: -320px;
  }

  .dashboard-grid.is-zen .timeline {
    grid-column: 1 / -1;
  }

  .catalog {
    position: sticky;
    top: 2rem;
    max-height: calc(100vh - 4rem);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .search-box input {
    width: 100%;
    min-height: 48px;
    padding: 0 var(--space-3);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .period-picker {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .period-picker span {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .period-picker select {
    min-height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    padding: 0 var(--space-2);
  }

  .catalog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    overflow-y: auto;
    padding-right: var(--space-2);
  }

  .section-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: inherit;
    text-align: left;
    cursor: pointer;
  }

  .section-card.is-selected {
    border-color: var(--color-primary);
    border-width: 2px;
    box-shadow: var(--shadow-lg);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 5%, var(--color-surface) 95%),
      var(--color-surface)
    );
  }

  .section-subtitle {
    margin: 0;
    font-size: 11px;
    color: var(--color-text-soft);
  }

  .workload-indicator {
    display: flex;
    gap: 3px;
    margin-top: 4px;
  }

  .workload-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-surface-muted);
    transition: all 0.2s ease;
  }

  .workload-dot.has-load {
    background: var(--color-text-soft);
  }

  .workload-dot.high-load {
    background: var(--color-primary);
    box-shadow: 0 0 4px var(--color-primary);
  }

  .section-card-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .section-card h3 {
    margin: 0;
    font-size: var(--font-size-lg);
  }

  .section-check,
  .catalog-count {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .section-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .section-meta span {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.55rem;
    border-radius: var(--radius-full);
    background: var(--color-surface-muted);
    color: var(--color-text-soft);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
  }

  .timeline-scroll {
    overflow: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    position: relative;
    max-height: 80vh;
  }

  .timeline-grid {
    display: grid;
    gap: 1px;
    background: var(--color-border);
    min-width: 100%;
    --cell-height: 5rem;
  }

  .timeline-grid > div {
    background: var(--color-surface);
  }

  .timeline-corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 30;
    background: var(--color-surface-muted) !important;
  }

  .timeline-day {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3);
    background: var(--color-surface-muted) !important;
    border-bottom: 2px solid var(--color-primary);
  }

  .timeline-day span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .timeline-time {
    position: sticky;
    left: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    background: var(--color-surface-muted) !important;
    border-right: 1px solid var(--color-border);
    gap: 2px;
  }

  .timeline-time.is-break {
    background: color-mix(
      in srgb,
      var(--color-surface-muted) 80%,
      var(--color-bg)
    ) !important;
  }

  .slot-label {
    font-size: 9px;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    opacity: 0.7;
  }

  .slot-range {
    font-size: 9px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--color-text-soft);
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    white-space: nowrap;
  }

  .schedule-tile[hidden] {
    display: none !important;
  }

  .timeline-cell {
    min-height: var(--cell-height);
    padding: 2px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .timeline-time.is-empty,
  .timeline-cell.is-empty {
    min-height: 1.5rem !important;
    max-height: 1.5rem;
  }

  .timeline-cell.is-empty .break-label {
    font-size: 8px;
  }

  .timeline-cell.is-break {
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 5px,
      color-mix(in srgb, var(--color-surface-muted) 30%, transparent) 5px,
      color-mix(in srgb, var(--color-surface-muted) 30%, transparent) 10px
    ) !important;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
  }

  .break-label {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  .timeline-cell:empty {
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      color-mix(in srgb, var(--color-surface-muted) 40%, transparent) 10px,
      color-mix(in srgb, var(--color-surface-muted) 40%, transparent) 20px
    );
  }

  .timeline-empty {
    padding: var(--space-8);
    text-align: center;
  }

  .timeline-empty h3 {
    margin-bottom: var(--space-2);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1100px) {
    .hero-grid,
    .dashboard-grid {
      grid-template-columns: 1fr;
    }

    .catalog {
      position: static;
      max-height: none;
    }

    .timeline-time span {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }
</style>
