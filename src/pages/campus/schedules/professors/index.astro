---
import AppLayout from "@/layouts/AppLayout.astro";
import {
  dayNames,
  getScheduleSummary,
  resolveScheduleDatasetByYearTerm,
  scheduleBlocks,
  schedulePeriods,
} from "@/lib/schedules";
import ProfessorStatsBanner from "@/features/schedules/components/composition/ProfessorStatsBanner.astro";
import ProfessorCatalog from "@/features/schedules/components/composition/ProfessorCatalog.astro";
import ProfessorWeeklyGrid from "@/features/schedules/components/composition/ProfessorWeeklyGrid.astro";
import { dayOrder } from "@/lib/schedules/constants";

const yearParam = Astro.url.searchParams.get("year");
const termParam = Astro.url.searchParams.get("term");
const dataset = resolveScheduleDatasetByYearTerm(yearParam, termParam);
const semesterLabel = dataset.period.label;
const scheduleEntries = dataset.entries;
const professorSchedules = dataset.professorSchedules;
const professorNames = Object.keys(professorSchedules).sort(
  new Intl.Collator("es", { sensitivity: "base" }).compare,
);

const getProfessorEntries = (name: string) => {
  const professor = professorSchedules[name];
  if (!professor) return [];
  return dayOrder.flatMap((day) => professor.by_day[day] ?? []);
};

const activeDays = dayNames.filter((day) =>
  scheduleEntries.some((entry) => entry.day === day.code),
);
const initialProfessor = professorNames[0] ?? "";
const initialEntries = getProfessorEntries(initialProfessor);
const summary = getScheduleSummary(scheduleEntries);
const activeSummary = getScheduleSummary(initialEntries);
---

<AppLayout
  title={`Horarios de Profesores | ${semesterLabel}`}
  description="Vista compacta de horarios para profesores, con búsqueda por nombre y grilla por bloques."
>
  <ProfessorStatsBanner
    semesterLabel={semesterLabel}
    totalEntries={summary.totalEntries}
    initialProfessor={initialProfessor}
    initialSessionCount={activeSummary.totalEntries}
    schedulePeriods={schedulePeriods}
    currentPeriodId={dataset.period.id}
  />

  <section class="section pt-0">
    <div
      class="container dashboard-grid"
      data-initial-professor={initialProfessor}
    >
      <ProfessorCatalog
        professorNames={professorNames}
        professorSchedules={professorSchedules}
        initialProfessor={initialProfessor}
      />

      <ProfessorWeeklyGrid
        activeDays={activeDays}
        scheduleBlocks={scheduleBlocks}
        professorSchedules={professorSchedules}
        professorNames={professorNames}
      />
    </div>
  </section>

  <script>
    import { initProfessorScheduleState } from "@/features/schedules/state/professorScheduleState";

    // Initialize state when the script runs
    initProfessorScheduleState();

    // Support for view transitions if enabled
    document.addEventListener("astro:page-load", () => {
      initProfessorScheduleState();
    });
  </script>
</AppLayout>

<style>
  .dashboard-grid {
    display: grid;
    grid-template-columns: 22rem 1fr;
    gap: var(--space-6);
    align-items: start;
    max-width: 100% !important;
    padding: 0 var(--space-6);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Zen Mode */
  .dashboard-grid.is-zen {
    grid-template-columns: 0px 1fr;
    gap: 0;
  }

  .dashboard-grid.is-zen :global(.catalog) {
    transform: translateX(-100%);
    opacity: 0;
    pointer-events: none;
    margin-right: -320px;
  }

  .dashboard-grid.is-zen :global(.timeline) {
    grid-column: 1 / -1;
  }

  @media (max-width: 1100px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
