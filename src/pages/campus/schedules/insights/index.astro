---
import AppLayout from '../../../../layouts/AppLayout.astro';
import { dayNames, getEntryDuration, professorNames, roomNames, scheduleEntries, semesterLabel, subjectNames, majors } from '../../../../data/schedulesData';

const dayMetrics = dayNames.map(({ code, label }) => {
  const entries = scheduleEntries.filter((entry) => entry.day === code);
  const totalBlocks = entries.reduce((total, entry) => total + getEntryDuration(entry), 0);

  return {
    code,
    label,
    entries: entries.length,
    blocks: totalBlocks,
  };
});

const majorMetrics = majors.map((major) => ({
  major,
  count: scheduleEntries.filter((entry) => entry.majors.includes(major)).length,
}));

const roomMetrics = roomNames
  .map((room) => ({
    room,
    count: scheduleEntries.filter((entry) => entry.room === room).length,
  }))
  .sort((left, right) => right.count - left.count || left.room.localeCompare(right.room));

const blockMetrics = dayNames
  .flatMap(({ code }) => scheduleEntries.filter((entry) => entry.day === code))
  .reduce<Record<string, number>>((accumulator, entry) => {
    const key = `${entry.start_block} - ${entry.end_block}`;
    accumulator[key] = (accumulator[key] ?? 0) + 1;
    return accumulator;
  }, {});

const blockRanking = Object.entries(blockMetrics)
  .map(([label, count]) => ({ label, count }))
  .sort((left, right) => right.count - left.count || left.label.localeCompare(right.label));

const totals = {
  courses: subjectNames.length,
  groups: new Set(scheduleEntries.map((entry) => `${entry.day}-${entry.group}`)).size,
  professors: professorNames.length,
  rooms: roomNames.length,
  entries: scheduleEntries.length,
};

const topBlock = blockRanking[0];
---

<AppLayout title={`Insights de Horarios | ${semesterLabel}`} description="Resumen analítico del dataset de horarios académicos procesados por el hub.">
  <section class="section schedule-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Insights</p>
        <h1 class="hero-title">Lecturas rápidas sobre el dataset académico.</h1>
        <p class="hero-text text-soft">
          Esta vista convierte el horario en información útil: distribución por carrera, carga diaria, aulas más usadas y bloques críticos.
        </p>
      </div>

      <div class="card summary-card">
        <div class="summary-grid">
          <div><span>Cursos</span><strong>{totals.courses}</strong></div>
          <div><span>Grupos</span><strong>{totals.groups}</strong></div>
          <div><span>Profesores</span><strong>{totals.professors}</strong></div>
          <div><span>Aulas</span><strong>{totals.rooms}</strong></div>
        </div>

        <p class="text-soft">
          Total de entradas procesadas: <strong>{totals.entries}</strong>. Las métricas muestran cobertura de horarios, no matrícula real.
        </p>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container insight-grid">
      <article class="card insight-card">
        <p class="eyebrow">Carga por día</p>
        <h2>Horarios distribuidos a lo largo de la semana</h2>

        <div class="metric-list">
          {dayMetrics.map((metric) => (
            <div class="metric-row">
              <div>
                <strong>{metric.label}</strong>
                <span>{metric.entries} clases</span>
              </div>
              <div class="metric-bar"><span style={`width: ${Math.max(10, (metric.blocks / Math.max(...dayMetrics.map((item) => item.blocks || 1))) * 100)}%`}></span></div>
            </div>
          ))}
        </div>
      </article>

      <article class="card insight-card">
        <p class="eyebrow">Carreras</p>
        <h2>Distribución por programa académico</h2>

        <div class="metric-list">
          {majorMetrics.map((metric) => (
            <div class="metric-row">
              <div>
                <strong>{metric.major}</strong>
                <span>{metric.count} entradas</span>
              </div>
              <div class="metric-bar"><span style={`width: ${Math.max(10, (metric.count / Math.max(...majorMetrics.map((item) => item.count || 1))) * 100)}%`}></span></div>
            </div>
          ))}
        </div>
      </article>

      <article class="card insight-card">
        <p class="eyebrow">Aulas</p>
        <h2>Espacios más utilizados</h2>

        <div class="metric-list compact-list">
          {roomMetrics.slice(0, 6).map((metric) => (
            <div class="metric-row compact-row">
              <div>
                <strong>{metric.room}</strong>
                <span>{metric.count} usos</span>
              </div>
              <div class="metric-bar"><span style={`width: ${Math.max(10, (metric.count / Math.max(...roomMetrics.map((item) => item.count || 1))) * 100)}%`}></span></div>
            </div>
          ))}
        </div>
      </article>

      <article class="card insight-card">
        <p class="eyebrow">Bloques críticos</p>
        <h2>Franjas horarias más cargadas</h2>

        <div class="block-card">
          <strong>{topBlock?.label ?? 'Sin datos'}</strong>
          <p class="text-soft">{topBlock ? `${topBlock.count} apariciones` : 'No hay bloques para analizar todavía.'}</p>
        </div>

        <div class="metric-list compact-list">
          {blockRanking.slice(0, 5).map((metric) => (
            <div class="metric-row compact-row">
              <div>
                <strong>{metric.label}</strong>
                <span>{metric.count} veces</span>
              </div>
              <div class="metric-bar"><span style={`width: ${Math.max(10, (metric.count / Math.max(...blockRanking.map((item) => item.count || 1))) * 100)}%`}></span></div>
            </div>
          ))}
        </div>
      </article>
    </div>
  </section>
</AppLayout>

<style>
  .schedule-hero {
    padding-bottom: var(--space-8);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  .hero-title {
    margin: var(--space-3) 0;
    font-size: clamp(2.2rem, 5vw, 4rem);
    max-width: 14ch;
  }

  .hero-text {
    max-width: 60ch;
    font-size: var(--font-size-lg);
  }

  .summary-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .summary-grid div {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
  }

  .summary-grid span {
    display: block;
    margin-bottom: var(--space-1);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .summary-grid strong {
    font-size: var(--font-size-2xl);
  }

  .insight-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .insight-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .metric-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .metric-row {
    display: grid;
    grid-template-columns: minmax(0, 180px) minmax(0, 1fr);
    gap: var(--space-4);
    align-items: center;
  }

  .metric-row strong {
    display: block;
    font-size: var(--font-size-sm);
  }

  .metric-row span {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .metric-bar {
    width: 100%;
    height: 10px;
    border-radius: var(--radius-full);
    background: var(--color-surface-muted);
    overflow: hidden;
  }

  .metric-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }

  .compact-row {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }

  .block-card {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
  }

  .block-card strong {
    display: block;
    margin-bottom: var(--space-1);
    font-size: var(--font-size-lg);
  }

  @media (max-width: 960px) {
    .hero-grid,
    .insight-grid {
      grid-template-columns: 1fr;
    }

    .metric-row {
      grid-template-columns: 1fr;
    }
  }
</style>
