---
import AppLayout from '../../../../layouts/AppLayout.astro';
import ScheduleTile from '../../../../components/Schedules/ScheduleTile.astro';
import {
  academicYears,
  buildScheduleSections,
  dayNames,
  formatAcademicYear,
  formatBlock,
  getScheduleSummary,
  majors,
  resolveScheduleDatasetByYearTerm,
  scheduleBlocks,
  schedulePeriods,
} from '../../../../data/schedulesData';

const yearParam = Astro.url.searchParams.get('year');
const termParam = Astro.url.searchParams.get('term');
const dataset = resolveScheduleDatasetByYearTerm(yearParam, termParam);
const semesterLabel = dataset.period.label;
const scheduleEntries = dataset.entries;
const periodMajors = [...new Set(scheduleEntries.flatMap((entry) => entry.majors))].sort(new Intl.Collator('es', { sensitivity: 'base' }).compare);
const periodYears = [...new Set(scheduleEntries.map((entry) => entry.academicYear).filter((year) => year > 0))].sort((left, right) => left - right);
const allSections = buildScheduleSections(scheduleEntries);
const activeDays = dayNames.filter((day) => scheduleEntries.some((entry) => entry.day === day.code));
const initialMajor = periodMajors.includes('ICE') ? 'ICE' : periodMajors[0] ?? 'all';
const initialYear = periodYears[0] ?? academicYears[0] ?? 0;
const initialSections = allSections.filter((section) =>
  section.majors.includes(initialMajor) && (initialYear <= 0 || section.academicYears.includes(initialYear))
);
const summary = getScheduleSummary(scheduleEntries);
---

<AppLayout title={`Horarios de Estudiantes | ${semesterLabel}`} description="Vista compacta de horarios para estudiantes, con selector de carrera y grilla por bloques.">
  <section class="section schedule-hero" data-initial-major={initialMajor} data-initial-year={String(initialYear)}>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Vista de estudiantes</p>
        <h1 class="hero-title">Selecciona carrera y año para ver solo lo que toca.</h1>
        <p class="hero-text text-soft">Cada clase ahora indica si es de 1°, 2°, 3° o 4° año.</p>
      </div>

      <div class="card hero-panel">
        <div class="panel-top">
          <span class="panel-tag">Periodo activo</span>
          <strong>{semesterLabel}</strong>
        </div>

        <label class="period-picker">
          <span>Periodo</span>
          <select id="period-select">
            {schedulePeriods.map((period) => (
              <option value={period.id} selected={period.id === dataset.period.id}>{period.label}</option>
            ))}
          </select>
        </label>

        <div class="panel-grid">
          <div>
            <span>Total de clases</span>
            <strong>{summary.totalEntries}</strong>
          </div>
          <div>
            <span>Secciones visibles</span>
            <strong id="selected-section-count">{initialSections.length}</strong>
          </div>
          <div>
            <span>Sesiones activas</span>
            <strong id="selected-session-count">{initialSections.reduce((total, section) => total + section.entries.length, 0)}</strong>
          </div>
          <div>
            <span>Profesores activos</span>
            <strong id="selected-professor-count">{new Set(initialSections.map((section) => section.professor)).size}</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container filter-strip card">
      <div class="filter-group">
        <p class="eyebrow">Carrera</p>
        <div class="major-buttons" role="tablist" aria-label="Seleccionar carrera">
          {periodMajors.map((major) => (
            <button type="button" class:list={['major-button', { 'is-active': major === initialMajor }]} data-major-button data-major={major}>{major}</button>
          ))}
        </div>
      </div>

      <div class="filter-group">
        <p class="eyebrow">Año</p>
        <div class="year-buttons" role="tablist" aria-label="Seleccionar año">
          {periodYears.map((year) => (
            <button type="button" class:list={['year-button', { 'is-active': year === initialYear }]} data-year-button data-year={String(year)}>{formatAcademicYear(year)}</button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container dashboard-grid">
      <aside class="catalog card">
        <div class="catalog-head">
          <div>
            <p class="eyebrow">Catálogo</p>
            <h2>Materias y grupos</h2>
          </div>
          <p class="catalog-count text-soft"><span id="visible-section-count">{initialSections.length}</span> secciones</p>
        </div>

        <label class="search-box">
          <span class="sr-only">Buscar</span>
          <input id="section-search" type="search" placeholder="Buscar materia, profesor o aula" />
        </label>

        <div class="catalog-list">
          {allSections.map((section) => (
            <button
              type="button"
              class:list={['section-card', { 'is-selected': section.majors.includes(initialMajor) && (initialYear <= 0 || section.academicYears.includes(initialYear)) }]}
              data-section-toggle
              data-section-id={section.id}
              data-major-list={section.majors.map((major) => major.toLowerCase()).join('|')}
              data-year-list={section.academicYears.map((year) => String(year)).join('|')}
              data-search={`${section.subject} ${section.professor} ${section.room} ${section.group}`.toLowerCase()}
              aria-pressed={section.majors.includes(initialMajor)}
            >
              <div class="section-card-top">
                <h3>{section.subject}</h3>
                <span class="section-check">Incluida</span>
              </div>
              <p class="section-professor">{section.professor}</p>
              <div class="section-meta">
                <span>G{section.group}</span>
                <span>{section.room}</span>
                <span>{section.academicYears.map((year) => formatAcademicYear(year)).join(' · ')}</span>
              </div>
            </button>
          ))}
        </div>
      </aside>

      <main class="timeline card">
        <div class="timeline-scroll">
          <div class="timeline-grid" style={`grid-template-columns: 6rem repeat(${activeDays.length}, minmax(12.5rem, 1fr));`}>
            <div class="timeline-corner">Hora</div>
            {activeDays.map((day) => <div class="timeline-day">{day.label}</div>)}

            {scheduleBlocks.map((block) => (
              <>
                <div class="timeline-time">{formatBlock(block)}</div>
                {activeDays.map((day) => {
                  const tilesForCell = allSections.flatMap((section) =>
                    section.entries
                      .filter((entry) => entry.day === day.code && entry.start_block === block)
                      .map((entry) => ({ entry, sectionId: section.id }))
                  );

                  return (
                    <div class="timeline-cell">
                      {tilesForCell.map(({ entry, sectionId }) => (
                        <ScheduleTile entry={entry} sectionId={sectionId} label={entry.subject} />
                      ))}
                    </div>
                  );
                })}
              </>
            ))}
          </div>
        </div>
      </main>
    </div>
  </section>

  <script is:inline>
    const boot = document.querySelector('[data-initial-major]');
    const initialMajor = boot?.dataset.initialMajor ?? 'all';
    const initialYear = boot?.dataset.initialYear ?? '0';
    const majorButtons = [...document.querySelectorAll('[data-major-button]')];
    const yearButtons = [...document.querySelectorAll('[data-year-button]')];
    const sectionButtons = [...document.querySelectorAll('[data-section-toggle]')];
    const tiles = [...document.querySelectorAll('[data-schedule-tile]')];
    const searchInput = document.getElementById('section-search');
    const periodSelect = document.getElementById('period-select');
    const visibleSectionCount = document.getElementById('visible-section-count');
    const selectedSectionCount = document.getElementById('selected-section-count');
    const selectedSessionCount = document.getElementById('selected-session-count');
    const selectedProfessorCount = document.getElementById('selected-professor-count');

    const state = {
      major: initialMajor,
      year: initialYear,
      selectedIds: new Set(),
    };

    const isSectionVisible = (button) => {
      const majors = button.dataset.majorList?.split('|') ?? [];
      const years = button.dataset.yearList?.split('|') ?? [];
      const query = searchInput?.value.trim().toLowerCase() ?? '';
      const search = button.dataset.search ?? '';

      return (
        majors.includes(state.major.toLowerCase())
        && years.includes(state.year)
        && (query.length === 0 || search.includes(query))
      );
    };

    const updateSummary = () => {
      const activeIds = new Set(
        sectionButtons
          .filter((button) => !button.hidden && state.selectedIds.has(button.dataset.sectionId ?? ''))
          .map((button) => button.dataset.sectionId ?? '')
      );
      const selectedTiles = tiles.filter((tile) => activeIds.has(tile.dataset.sectionId ?? ''));
      const selectedProfessors = new Set(selectedTiles.map((tile) => tile.dataset.professor ?? ''));

      selectedSectionCount.textContent = String(activeIds.size);
      selectedSessionCount.textContent = String(selectedTiles.length);
      selectedProfessorCount.textContent = String(selectedProfessors.size);
    };

    const applySelectionState = () => {
      sectionButtons.forEach((button) => {
        const sectionId = button.dataset.sectionId ?? '';
        const selected = state.selectedIds.has(sectionId);
        const visible = isSectionVisible(button);
        const check = button.querySelector('.section-check');

        button.hidden = !visible;
        button.classList.toggle('is-selected', selected);
        button.setAttribute('aria-pressed', String(selected));

        if (check) {
          check.textContent = selected ? 'Incluida' : 'Disponible';
        }
      });

      const activeIds = new Set(
        sectionButtons
          .filter((button) => !button.hidden && state.selectedIds.has(button.dataset.sectionId ?? ''))
          .map((button) => button.dataset.sectionId ?? '')
      );

      tiles.forEach((tile) => {
        tile.hidden = !activeIds.has(tile.dataset.sectionId ?? '');
      });

      visibleSectionCount.textContent = String(sectionButtons.filter((button) => !button.hidden).length);
      updateSummary();
    };

    const refreshSelection = () => {
      state.selectedIds = new Set(
        sectionButtons
          .filter((button) => {
            const majors = button.dataset.majorList?.split('|') ?? [];
            const years = button.dataset.yearList?.split('|') ?? [];
            return majors.includes(state.major.toLowerCase()) && years.includes(state.year);
          })
          .map((button) => button.dataset.sectionId ?? '')
      );

      applySelectionState();
    };

    majorButtons.forEach((button) => {
      button.addEventListener('click', () => {
        state.major = button.dataset.major ?? state.major;
        majorButtons.forEach((candidate) => candidate.classList.toggle('is-active', candidate === button));
        refreshSelection();
      });
    });

    yearButtons.forEach((button) => {
      button.addEventListener('click', () => {
        state.year = button.dataset.year ?? state.year;
        yearButtons.forEach((candidate) => candidate.classList.toggle('is-active', candidate === button));
        refreshSelection();
      });
    });

    sectionButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const sectionId = button.dataset.sectionId ?? '';
        if (state.selectedIds.has(sectionId)) {
          state.selectedIds.delete(sectionId);
        } else {
          state.selectedIds.add(sectionId);
        }

        applySelectionState();
      });
    });

    searchInput?.addEventListener('input', applySelectionState);

    periodSelect?.addEventListener('change', () => {
      const selected = periodSelect.value;
      const [year, term] = selected.split('-');
      const nextUrl = new URL(window.location.href);
      nextUrl.searchParams.set('year', year ?? '');
      nextUrl.searchParams.set('term', term ?? '');
      window.location.assign(nextUrl.toString());
    });

    refreshSelection();
  </script>
</AppLayout>

<style>
  .hero-grid,
  .dashboard-grid {
    display: grid;
    gap: var(--space-4);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    align-items: stretch;
  }

  .dashboard-grid {
    grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.6fr);
    align-items: start;
  }

  .hero-copy,
  .hero-panel,
  .catalog,
  .timeline,
  .filter-strip {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .filter-strip {
    gap: var(--space-4);
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .major-buttons,
  .year-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .major-button,
  .year-button {
    min-height: 36px;
    padding: 0 var(--space-3);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-soft);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    font-size: var(--font-size-xs);
  }

  .major-button.is-active,
  .year-button.is-active {
    background: var(--color-primary);
    color: var(--color-text-on-brand);
    border-color: var(--color-primary);
  }

  .catalog {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 110px);
  }

  .catalog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    overflow: auto;
    padding-right: var(--space-1);
  }

  .section-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    cursor: pointer;
    text-align: left;
  }

  .section-card.is-selected {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, var(--color-surface));
  }

  .section-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .section-card h3,
  .hero-title,
  .timeline-day,
  .timeline-time,
  .timeline-corner,
  .eyebrow {
    margin: 0;
  }

  .section-professor {
    margin: 0;
    font-size: var(--font-size-xs);
    color: var(--color-text-soft);
  }

  .section-meta {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
  }

  .section-meta span,
  .section-check,
  .catalog-count,
  .eyebrow {
    font-size: var(--font-size-xs);
  }

  .section-meta span {
    padding: 0.2rem 0.45rem;
    border-radius: var(--radius-full);
    background: var(--color-surface-muted);
  }

  .timeline-scroll {
    overflow: auto;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .timeline-grid {
    display: grid;
    gap: 1px;
    background: var(--color-border);
  }

  .timeline-grid > div {
    background: var(--color-surface);
  }

  .timeline-corner,
  .timeline-day,
  .timeline-time {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    background: var(--color-surface-muted);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .timeline-cell {
    min-height: 6.5rem;
    padding: var(--space-1);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .search-box input,
  .period-picker select {
    width: 100%;
    min-height: 38px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    padding: 0 var(--space-2);
    background: var(--color-surface);
    color: var(--color-text);
  }

  @media (max-width: 1100px) {
    .hero-grid,
    .dashboard-grid {
      grid-template-columns: 1fr;
    }

    .catalog {
      position: static;
      max-height: none;
    }
  }
</style>
