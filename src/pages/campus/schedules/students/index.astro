---
import AppLayout from "@/layouts/AppLayout.astro";
import {
  academicYears,
  buildScheduleSections,
  dayNames,
  getScheduleSummary,
  resolveScheduleDatasetByYearTerm,
  scheduleBlocks,
  schedulePeriods,
  findValidPath,
} from "@/lib/schedules";
import StudentScheduleCatalog from "@/features/schedules/components/composition/StudentScheduleCatalog.astro";
import StudentScheduleFilters from "@/features/schedules/components/composition/StudentScheduleFilters.astro";
import StudentScheduleTimeline from "@/features/schedules/components/composition/StudentScheduleTimeline.astro";
import Badge from "@/components/UI/Badge.astro";

const yearParam = Astro.url.searchParams.get("year");
const termParam = Astro.url.searchParams.get("term");
const dataset = resolveScheduleDatasetByYearTerm(yearParam, termParam);
const semesterLabel = dataset.period.label;
const scheduleEntries = dataset.entries;
const periodMajors = [
  ...new Set(scheduleEntries.flatMap((entry) => entry.majors)),
].sort(new Intl.Collator("es", { sensitivity: "base" }).compare);
const periodYears = [
  ...new Set(
    scheduleEntries
      .map((entry) => entry.academicYear)
      .filter((year) => year > 0),
  ),
].sort((left, right) => left - right);
const allSections = buildScheduleSections(scheduleEntries);
const activeDays = dayNames.filter((day) =>
  scheduleEntries.some((entry) => entry.day === day.code),
);
const initialMajor = periodMajors.includes("ICE")
  ? "ICE"
  : (periodMajors[0] ?? "all");
const initialYear = periodYears[0] ?? academicYears[0] ?? 0;
const initialSections = allSections.filter(
  (section) =>
    section.majors.includes(initialMajor) &&
    (initialYear <= 0 || section.academicYears.includes(initialYear)),
);
const summary = getScheduleSummary(scheduleEntries);

const suggestedPath = findValidPath(initialSections);
const integrityError = suggestedPath === null;

const activeSummary = {
  totalEntries: initialSections.reduce(
    (total, section) => total + section.entries.length,
    0,
  ),
  totalSections: initialSections.length,
};
---

<AppLayout
  title={`Horarios de Estudiantes | ${semesterLabel}`}
  description="Vista compacta de horarios para estudiantes, con selector de carrera y grilla por bloques."
>
  <header
    class="stats-banner"
    data-initial-major={initialMajor}
    data-initial-year={String(initialYear)}
    data-integrity-error={String(integrityError)}
  >
    <div class="container stats-container">
      <div class="stats-header">
        <p class="eyebrow">Vista de Estudiantes</p>
        <h2>{semesterLabel}</h2>
      </div>

      <div class="stats-group">
        <div class="stat-item">
          <span>Carrera activa</span>
          <Badge variant="primary" id="active-major-badge">{initialMajor}</Badge
          >
        </div>
        <div class="stat-item">
          <span>Año Académico</span>
          <Badge variant="muted" id="active-year-badge"
            >{initialYear}° Año</Badge
          >
        </div>
        <div class="stat-item">
          <span>Secciones</span>
          <Badge variant="muted" id="selected-section-count"
            >{activeSummary.totalSections}</Badge
          >
        </div>
        <div class="stat-item">
          <span>Sesiones / Sem</span>
          <Badge variant="muted" id="selected-session-count"
            >{activeSummary.totalEntries}</Badge
          >
        </div>
      </div>

      <div class="stats-actions">
        <StudentScheduleFilters
          schedulePeriods={schedulePeriods}
          activePeriodId={dataset.period.id}
          periodMajors={periodMajors}
          initialMajor={initialMajor}
          periodYears={periodYears}
          initialYear={initialYear}
          variant="compact"
        />
      </div>
    </div>
  </header>

  <section class="section pt-0">
    <div class="container dashboard-grid" id="main-dashboard">
      <StudentScheduleCatalog
        allSections={allSections}
        initialMajor={initialMajor}
        initialYear={initialYear}
        initialVisibleSections={initialSections.length}
      />

      <StudentScheduleTimeline
        activeDays={activeDays}
        scheduleBlocks={scheduleBlocks}
        allSections={allSections}
      />
    </div>
  </section>

  <script type="module">
    import { initStudentScheduleState } from "/src/features/schedules/state/studentScheduleState.ts";
    initStudentScheduleState();

    // Sincronización de Zen Mode
    const zenToggle = document.getElementById("zen-mode-toggle");
    const dashboard = document.getElementById("main-dashboard");

    zenToggle?.addEventListener("click", () => {
      dashboard?.classList.toggle("is-zen");
      zenToggle.textContent = dashboard?.classList.contains("is-zen")
        ? "Ver Catálogo"
        : "Vista dedicada";
    });
  </script>
</AppLayout>

<style>
  .hero-grid,
  .dashboard-grid {
    display: grid;
    gap: var(--space-4);
  }

  /* Stats Banner */
  .stats-banner {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  .stats-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .stats-header h2 {
    font-size: var(--font-size-xl);
    margin: 0;
  }

  .stats-group {
    display: flex;
    gap: var(--space-8);
    flex: 1;
    justify-content: center;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .stat-item span {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    align-items: stretch;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.6fr);
    gap: var(--space-4);
    align-items: start;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Zen Mode */
  .dashboard-grid.is-zen {
    grid-template-columns: 0px 1fr;
    gap: 0;
  }

  .dashboard-grid.is-zen :global(.catalog) {
    transform: translateX(-100%);
    opacity: 0;
    pointer-events: none;
    margin-right: -320px;
  }

  .dashboard-grid.is-zen :global(.timeline) {
    grid-column: 1 / -1;
  }

  .hero-copy,
  .hero-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .panel-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .panel-grid div {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
  }

  .panel-grid span {
    display: block;
    margin-bottom: var(--space-1);
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-title,
  .eyebrow,
  .panel-tag {
    margin: 0;
  }

  .eyebrow,
  .panel-tag {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  .hero-title {
    font-size: clamp(2rem, 4vw, 3.4rem);
    max-width: 14ch;
  }

  .hero-text {
    max-width: 56ch;
    font-size: var(--font-size-base);
  }

  @media (max-width: 1100px) {
    .hero-grid,
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
