---
import AppLayout from '../../../../layouts/AppLayout.astro';
import {
  academicYears,
  buildScheduleSections,
  dayNames,
  getScheduleSummary,
  resolveScheduleDatasetByYearTerm,
  scheduleBlocks,
  schedulePeriods,
} from '../../../../lib/schedules';
import StudentScheduleCatalog from '../../../../features/schedules/components/StudentScheduleCatalog.astro';
import StudentScheduleFilters from '../../../../features/schedules/components/StudentScheduleFilters.astro';
import StudentScheduleTimeline from '../../../../features/schedules/components/StudentScheduleTimeline.astro';

const yearParam = Astro.url.searchParams.get('year');
const termParam = Astro.url.searchParams.get('term');
const dataset = resolveScheduleDatasetByYearTerm(yearParam, termParam);
const semesterLabel = dataset.period.label;
const scheduleEntries = dataset.entries;
const periodMajors = [...new Set(scheduleEntries.flatMap((entry) => entry.majors))].sort(new Intl.Collator('es', { sensitivity: 'base' }).compare);
const periodYears = [...new Set(scheduleEntries.map((entry) => entry.academicYear).filter((year) => year > 0))].sort((left, right) => left - right);
const allSections = buildScheduleSections(scheduleEntries);
const activeDays = dayNames.filter((day) => scheduleEntries.some((entry) => entry.day === day.code));
const initialMajor = periodMajors.includes('ICE') ? 'ICE' : periodMajors[0] ?? 'all';
const initialYear = periodYears[0] ?? academicYears[0] ?? 0;
const initialSections = allSections.filter((section) =>
  section.majors.includes(initialMajor) && (initialYear <= 0 || section.academicYears.includes(initialYear))
);
const summary = getScheduleSummary(scheduleEntries);
---

<AppLayout title={`Horarios de Estudiantes | ${semesterLabel}`} description="Vista compacta de horarios para estudiantes, con selector de carrera y grilla por bloques.">
  <section class="section schedule-hero" data-initial-major={initialMajor} data-initial-year={String(initialYear)}>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Vista de estudiantes</p>
        <h1 class="hero-title">Selecciona carrera y año para ver solo lo que toca.</h1>
        <p class="hero-text text-soft">Cada clase ahora indica si es de 1°, 2°, 3° o 4° año.</p>
      </div>

      <div class="card hero-panel">
        <div class="panel-top">
          <span class="panel-tag">Periodo activo</span>
          <strong>{semesterLabel}</strong>
        </div>

        <div class="panel-grid">
          <div>
            <span>Total de clases</span>
            <strong>{summary.totalEntries}</strong>
          </div>
          <div>
            <span>Secciones visibles</span>
            <strong id="selected-section-count">{initialSections.length}</strong>
          </div>
          <div>
            <span>Sesiones activas</span>
            <strong id="selected-session-count">{initialSections.reduce((total, section) => total + section.entries.length, 0)}</strong>
          </div>
          <div>
            <span>Profesores activos</span>
            <strong id="selected-professor-count">{new Set(initialSections.map((section) => section.professor)).size}</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <StudentScheduleFilters
    schedulePeriods={schedulePeriods}
    activePeriodId={dataset.period.id}
    periodMajors={periodMajors}
    initialMajor={initialMajor}
    periodYears={periodYears}
    initialYear={initialYear}
  />

  <section class="section pt-0">
    <div class="container dashboard-grid">
      <StudentScheduleCatalog
        allSections={allSections}
        initialMajor={initialMajor}
        initialYear={initialYear}
        initialVisibleSections={initialSections.length}
      />

      <StudentScheduleTimeline activeDays={activeDays} scheduleBlocks={scheduleBlocks} allSections={allSections} />
    </div>
  </section>

  <script type="module">
    import { initStudentScheduleState } from '/src/features/schedules/state/studentScheduleState.ts';

    initStudentScheduleState();
  </script>
</AppLayout>

<style>
  .hero-grid,
  .dashboard-grid {
    display: grid;
    gap: var(--space-4);
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    align-items: stretch;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.6fr);
    gap: var(--space-4);
    align-items: start;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Zen Mode */
  .dashboard-grid.is-zen {
    grid-template-columns: 0px 1fr;
    gap: 0;
  }

  .dashboard-grid.is-zen :global(.catalog) {
    transform: translateX(-100%);
    opacity: 0;
    pointer-events: none;
    margin-right: -320px;
  }

  .dashboard-grid.is-zen :global(.timeline) {
    grid-column: 1 / -1;
  }

  .hero-copy,
  .hero-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .panel-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .panel-grid div {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
  }

  .panel-grid span {
    display: block;
    margin-bottom: var(--space-1);
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-title,
  .eyebrow,
  .panel-tag {
    margin: 0;
  }

  .eyebrow,
  .panel-tag {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  .hero-title {
    font-size: clamp(2rem, 4vw, 3.4rem);
    max-width: 14ch;
  }

  .hero-text {
    max-width: 56ch;
    font-size: var(--font-size-base);
  }

  @media (max-width: 1100px) {
    .hero-grid,
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
