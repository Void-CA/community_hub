---
import AppLayout from '@/layouts/AppLayout.astro';
import {
  buildScheduleSections,
  dayNames,
  resolveScheduleDatasetByYearTerm,
  scheduleBlocks,
  schedulePeriods,
  findValidPath,
} from '@/lib/schedules';
import StudentScheduleFilters from '@/features/schedules/components/composition/StudentScheduleFilters.astro';
import StudentScheduleDashboard from '@/features/schedules/components/composition/StudentScheduleDashboard.astro';

const yearParam = Astro.url.searchParams.get('year');
const termParam = Astro.url.searchParams.get('term');
const dataset = resolveScheduleDatasetByYearTerm(yearParam, termParam);
const semesterLabel = dataset.period.label;
const scheduleEntries = dataset.entries;
const periodMajors = [
  ...new Set(scheduleEntries.flatMap((entry) => entry.majors)),
].sort((a, b) =>
  new Intl.Collator('es', { sensitivity: 'base' }).compare(a, b),
);
const periodYears = [
  ...new Set(
    scheduleEntries
      .map((entry) => entry.academicYear)
      .filter((year) => year > 0),
  ),
].sort((left, right) => left - right);
const allSections = buildScheduleSections(scheduleEntries);
const activeDays = dayNames.filter((day) =>
  scheduleEntries.some((entry) => entry.day === day.code),
);
const initialMajor = periodMajors.includes('ICE')
  ? 'ICE'
  : (periodMajors[0] ?? 'all');
const initialYear = periodYears[0] ?? 0;
const initialSections = allSections.filter(
  (section) =>
    section.majors.includes(initialMajor) &&
    (initialYear <= 0 || section.academicYears.includes(initialYear)),
);
const suggestedPath = findValidPath(initialSections);
const integrityError = !suggestedPath.success;
---

<AppLayout
  title={`Horarios de Estudiantes | ${semesterLabel}`}
  description="Vista compacta de horarios para estudiantes, con selector de carrera y grilla por bloques."
>
  <StudentScheduleFilters
    schedulePeriods={schedulePeriods}
    activePeriodId={dataset.period.id}
    periodMajors={periodMajors}
    initialMajor={initialMajor}
    periodYears={periodYears}
    initialYear={initialYear}
  />

  <StudentScheduleDashboard
    allSections={allSections}
    initialMajor={initialMajor}
    initialYear={initialYear}
    initialVisibleSections={initialSections.length}
    activeDays={activeDays}
    scheduleBlocks={scheduleBlocks}
    integrityError={integrityError}
  />
</AppLayout>

<style>
  .hero-grid,
  .container-fluid {
    max-width: 100%;
    padding: 0 var(--space-4);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    margin-bottom: var(--space-1);
  }
</style>
