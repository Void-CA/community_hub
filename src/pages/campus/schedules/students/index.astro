---
import AppLayout from '@/layouts/AppLayout.astro';
import {
  buildScheduleSections,
  dayNames,
  resolveScheduleDatasetByYearTerm,
  scheduleBlocks,
  schedulePeriods,
  findValidPath,
} from '@/lib/schedules';
import StudentScheduleCatalog from '@/features/schedules/components/composition/StudentScheduleCatalog.astro';
import StudentScheduleFilters from '@/features/schedules/components/composition/StudentScheduleFilters.astro';
import StudentScheduleTimeline from '@/features/schedules/components/composition/StudentScheduleTimeline.astro';

const yearParam = Astro.url.searchParams.get('year');
const termParam = Astro.url.searchParams.get('term');
const dataset = resolveScheduleDatasetByYearTerm(yearParam, termParam);
const semesterLabel = dataset.period.label;
const scheduleEntries = dataset.entries;
const periodMajors = [
  ...new Set(scheduleEntries.flatMap((entry) => entry.majors)),
].sort((a, b) =>
  new Intl.Collator('es', { sensitivity: 'base' }).compare(a, b),
);
const periodYears = [
  ...new Set(
    scheduleEntries
      .map((entry) => entry.academicYear)
      .filter((year) => year > 0),
  ),
].sort((left, right) => left - right);
const allSections = buildScheduleSections(scheduleEntries);
const activeDays = dayNames.filter((day) =>
  scheduleEntries.some((entry) => entry.day === day.code),
);
const initialMajor = periodMajors.includes('ICE')
  ? 'ICE'
  : (periodMajors[0] ?? 'all');
const initialYear = periodYears[0] ?? 0;
const initialSections = allSections.filter(
  (section) =>
    section.majors.includes(initialMajor) &&
    (initialYear <= 0 || section.academicYears.includes(initialYear)),
);
const suggestedPath = findValidPath(initialSections);
const _integrityError = !suggestedPath.success;
---

<AppLayout
  title={`Horarios de Estudiantes | ${semesterLabel}`}
  description="Vista compacta de horarios para estudiantes, con selector de carrera y grilla por bloques."
>
  <StudentScheduleFilters
    schedulePeriods={schedulePeriods}
    activePeriodId={dataset.period.id}
    periodMajors={periodMajors}
    initialMajor={initialMajor}
    periodYears={periodYears}
    initialYear={initialYear}
  />

  <section
    class="dashboard-section"
    data-initial-major={initialMajor}
    data-initial-year={String(initialYear)}
  >
    <div class="container-fluid dashboard-layout" id="main-dashboard">
      <div class="dashboard-explorer">
        <StudentScheduleCatalog
          allSections={allSections}
          initialMajor={initialMajor}
          initialYear={initialYear}
          initialVisibleSections={initialSections.length}
        />
      </div>

      <div class="dashboard-timeline">
        <StudentScheduleTimeline
          activeDays={activeDays}
          scheduleBlocks={scheduleBlocks}
          allSections={allSections}
        />
      </div>
    </div>
  </section>

  <script type="module">
    import { initStudentScheduleState } from '/src/features/schedules/state/studentScheduleState.ts';
    initStudentScheduleState();

    // Sincronización de Zen Mode
    const zenToggle = document.getElementById('zen-mode-toggle');
    const dashboard = document.getElementById('main-dashboard');

    zenToggle?.addEventListener('click', () => {
      dashboard?.classList.toggle('is-zen');
      zenToggle.textContent = dashboard?.classList.contains('is-zen')
        ? 'Ver Catálogo'
        : 'Vista dedicada';
    });
  </script>
</AppLayout>

<style>
  .hero-grid,
  .container-fluid {
    max-width: 100%;
    padding: 0 var(--space-4);
  }

  .dashboard-section {
    padding: var(--space-4) 0;
  }

  .dashboard-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-4);
    align-items: start;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Zen Mode */
  .dashboard-layout.is-zen {
    grid-template-columns: 0px 1fr;
    gap: 0;
  }

  .dashboard-layout.is-zen .dashboard-explorer {
    transform: translateX(-100%);
    opacity: 0;
    pointer-events: none;
    margin-right: -280px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    margin-bottom: var(--space-1);
  }

  @media (max-width: 1200px) {
    .dashboard-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
