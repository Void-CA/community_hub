---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Recursos Académicos">
  <section class="section">
    <div class="container text-center">
      <h1>Recursos Académicos</h1>
      <p class="text-soft">Guías, explicaciones y material complementario para tu aprendizaje.</p>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="grid grid-cols-3">
        <div class="card">
          <h3>Trámites SIGA</h3>
          <p>Guía paso a paso para procesos administrativos.</p>
        </div>
        <div class="card">
          <h3>Consejos de Estudio</h3>
          <p>Técnicas probadas por otros estudiantes.</p>
        </div>
        <div class="card">
          <h3>Repositorio de Apuntes</h3>
          <p>Material compartido por la comunidad.</p>
        </div>
      </div>
    </div>
  </section>
</AppLayout>
