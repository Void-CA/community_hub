---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Laboratorio Beta">
  <section class="section">
    <div class="container text-center">
      <h1>Laboratorio</h1>
      <p class="text-soft">Espacio experimental para prototipos e ideas en exploración.</p>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container text-center">
      <div class="card">
        <span class="text-accent">Experimento #1</span>
        <h2>Diseño Generativo</h2>
        <p>Pruebas de visualización de datos académicos.</p>
      </div>
    </div>
  </section>
</AppLayout>
