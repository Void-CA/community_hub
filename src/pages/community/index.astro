---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Comunidad">
  <section class="section">
    <div class="container text-center">
      <h1>Comunidad</h1>
      <p class="text-soft">Proyectos y aportaciones de los propios estudiantes.</p>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <div class="card text-center">
        <h2>¿Tienes un proyecto?</h2>
        <p>El Hub es un espacio abierto para compartir tus herramientas.</p>
        <div class="section">
           <p class="text-muted">Aquí aparecerán los proyectos destacados de la comunidad.</p>
        </div>
      </div>
    </div>
  </section>
</AppLayout>
