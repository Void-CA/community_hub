---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import Button from '../../../components/UI/Button.astro';

const toolUrl = 'https://wrangler-horarios-voidca.netlify.app/';

const previewConfig = {
  label: 'Vista previa integrada',
  linkLabel: 'Abrir en nueva pestaña',
};

const fallbackConfig = {
  title: 'Abre el parser directamente',
  description:
    'Si la vista embebida no carga, puedes usar la herramienta externa sin salir del flujo del hub.',
  href: toolUrl,
  hrefLabel: 'Abrir herramienta',
};
---

<ToolLayout
  title="Parser de Horarios"
  description="Extrae la información de horarios desde PDFs en formato de tabla y la organiza automáticamente en un calendario estructurado por días, facilitando su lectura y uso."
  preview={previewConfig}
  fallback={fallbackConfig}
>
  <Button
    slot="actions"
    href={toolUrl}
    variant="primary"
    size="lg"
    target="_blank"
    rel="noreferrer"
  >
    Abrir herramienta
  </Button>

  <Button slot="actions" href="/tools" variant="secondary" size="lg">
    Volver a herramientas
  </Button>

  <iframe
    slot="preview"
    title="Parser de Horarios"
    src={toolUrl}
    loading="lazy"
    referrerpolicy="no-referrer"></iframe>
</ToolLayout>
