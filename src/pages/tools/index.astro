---
import AppLayout from '../../layouts/AppLayout.astro';
import ToolCard from '../../components/Tools/ToolCard.astro';
import ToolSection from '../../components/Tools/ToolSection.astro';
import { tools } from '../../data/tools';

// Grouping tools by category
const categories = [...new Set(tools.map(t => t.category || 'Otros'))];
---

<AppLayout title="Herramientas">
  <section class="section">
    <div class="container text-center hero-content">
      <h1 class="page-title">Catálogo de Herramientas</h1>
      <p class="text-soft page-subtitle">
        Utilidades diseñadas para resolver problemas concretos del día a día académico y técnico.
      </p>
    </div>
  </section>

  <div class="container">
    {categories.map(category => (
      <ToolSection 
        title={category}
      >
        {tools
          .filter(t => (t.category || 'Otros') === category)
          .map(tool => <ToolCard tool={tool} />)
        }
      </ToolSection>
    ))}
  </div>
</AppLayout>

<style>
  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-title {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-4);
  }

  .page-subtitle {
    font-size: var(--font-size-lg);
  }
</style>
