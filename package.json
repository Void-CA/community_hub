{
  "name": "ulsa-community-hub",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/ && stylelint \"src/**/*.{css,astro}\"",
    "lint:fix": "eslint src/ --fix && stylelint \"src/**/*.{css,astro}\" --fix",
    "lint:css": "stylelint \"src/**/*.{css,astro}\"",
    "lint:es": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lucide/astro": "^1.12.0",
    "astro": "^6.1.9",
    "lucide-astro": "^0.556.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}